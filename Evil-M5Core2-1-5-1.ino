// Trim util
void trimStringCCTV(String &s) {
  s.trim();
  // retire éventuel BOM UTF-8
  if (s.length() >= 3 && (uint8_t)s[0]==0xEF && (uint8_t)s[1]==0xBB && (uint8_t)s[2]==0xBF) {
    s.remove(0,3);
  }
}


