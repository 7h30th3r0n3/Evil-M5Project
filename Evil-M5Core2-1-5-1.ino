void waitAndReturnToMenu(String message) {
  const int screenWidth  = 320;
  const int screenHeight = 240;
  const int charWidth    = 12;   // approx char width at textSize(2)
  const int lineHeight   = 18;
  const int maxCharsPerLine = screenWidth / charWidth;  // ~26 chars

  M5.Display.clear();
  M5.Display.setTextSize(2);
  M5.Display.setTextColor(TFT_WHITE, TFT_BLACK);

  // Word-wrap: split message into lines
  std::vector<String> lines;
  String currentLine = "";
  for (int i = 0; i < (int)message.length(); i++) {
    char c = message.charAt(i);
    if (c == '\n') {
      lines.push_back(currentLine);
      currentLine = "";
      continue;
    }
    currentLine += c;
    if ((int)currentLine.length() >= maxCharsPerLine) {
      int lastSpace = currentLine.lastIndexOf(' ');
      if (lastSpace > 0) {
        lines.push_back(currentLine.substring(0, lastSpace));
        currentLine = currentLine.substring(lastSpace + 1);
      } else {
        lines.push_back(currentLine);
        currentLine = "";
      }
    }
  }
  if (currentLine.length() > 0) lines.push_back(currentLine);

  // Vertically center all lines
  int totalTextHeight = lines.size() * lineHeight;
  int startY = (screenHeight - totalTextHeight) / 2;
  if (startY < 4) startY = 4;

  // Horizontally center each line
  for (int i = 0; i < (int)lines.size(); i++) {
    int lineW = lines[i].length() * charWidth;
    int startX = (screenWidth - lineW) / 2;
    if (startX < 2) startX = 2;
    M5.Display.setCursor(startX, startY + i * lineHeight);
    M5.Display.println(lines[i]);
  }

  M5.Display.display();
  unsigned long _wr = millis();
  while (millis() - _wr < 1500) { handleDnsRequestSerial(); delay(50); }
  exitDebounce();
  inMenu = true;
  drawMenu();
}



