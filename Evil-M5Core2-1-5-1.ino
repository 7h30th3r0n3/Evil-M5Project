int ddCountFiles() {
  File dir = SD.open(DD_BASE);
  if (!dir) return 0;
  int n = 0;
  while (File f = dir.openNextFile()) { n++; f.close(); }
  dir.close();
  return n;
}

// Dashboard tile coords for 320x240
static const int DD_T_W = 96, DD_T_H = 36;
