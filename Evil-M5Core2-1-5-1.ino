void updateConnectedMACs() {
  wifi_sta_list_t stationList;
  tcpip_adapter_sta_list_t adapterList;
  esp_wifi_ap_get_sta_list(&stationList);
  tcpip_adapter_get_sta_list(&stationList, &adapterList);

  for (int i = 0; i < adapterList.num; i++) {
    char macStr[18];
    snprintf(macStr, sizeof(macStr), "%02X:%02X:%02X:%02X:%02X:%02X",
             adapterList.sta[i].mac[0], adapterList.sta[i].mac[1], adapterList.sta[i].mac[2],
             adapterList.sta[i].mac[3], adapterList.sta[i].mac[4], adapterList.sta[i].mac[5]);
    macAddresses[i] = String(macStr);
  }
}

void displayMonitorPage2() {
  const int lineHeight   = 18;
  const int topY         = 22;
  const int tickerH      = 20;
  const int listH        = 240 - topY - tickerH;
  const int maxVisible   = listH / lineHeight;

  int topIndex = 0;
  String prevMACs[10];
  int prevCount = 0;
  String ticker = "";
  unsigned long tickerUntil = 0;
  bool needRedraw = true;

  M5.Display.clear();
  M5.Display.setTextSize(2);
  M5.Display.setTextColor(menuTextUnFocusedColor, TFT_BLACK);

  updateConnectedMACs();
  for (int i = 0; i < 10; i++) prevMACs[i] = macAddresses[i];
  for (int i = 0; i < 10; i++) if (macAddresses[i] != "") prevCount++;

  unsigned long lastRefresh = 0;

  while (!inMenu) {
    kpSafeUpdate();
    handleDnsRequestSerial();

    // Refresh MACs periodically
    if (millis() - lastRefresh > 500) {
      String oldMACs[10];
      int oldCount = 0;
      for (int i = 0; i < 10; i++) { oldMACs[i] = prevMACs[i]; if (prevMACs[i] != "") oldCount++; }

      updateConnectedMACs();
      int newCount = 0;
      for (int i = 0; i < 10; i++) if (macAddresses[i] != "") newCount++;

      // Detect join/leave for ticker
      for (int n = 0; n < 10; n++) {
        if (macAddresses[n] == "") continue;
        bool found = false;
        for (int o = 0; o < 10; o++) { if (oldMACs[o] == macAddresses[n]) { found = true; break; } }
        if (!found) { ticker = "+ " + macAddresses[n]; tickerUntil = millis() + 3000; needRedraw = true; }
      }
      for (int o = 0; o < 10; o++) {
        if (oldMACs[o] == "") continue;
        bool found = false;
        for (int n = 0; n < 10; n++) { if (macAddresses[n] == oldMACs[o]) { found = true; break; } }
        if (!found) { ticker = "- " + oldMACs[o]; tickerUntil = millis() + 3000; needRedraw = true; }
      }

      bool changed = (oldCount != newCount);
      if (!changed) {
        for (int i = 0; i < 10; i++) { if (prevMACs[i] != macAddresses[i]) { changed = true; break; } }
      }
      if (changed) {
        for (int i = 0; i < 10; i++) prevMACs[i] = macAddresses[i];
        prevCount = newCount;
        if (topIndex > max(0, newCount - maxVisible)) topIndex = max(0, newCount - maxVisible);
        needRedraw = true;
      }
      lastRefresh = millis();
    }

    // Navigation
    if (kp(KEY_BACKSPACE)) { displayMonitorPage1(); break; }
    if (kp('.')) { displayMonitorPage3(); break; }
    if (kp(KEY_ENTER)) { returnToMainMenu(); break; }

    // Scroll with PWR
    if (M5.BtnPWR.wasClicked()) {
      int numMACs = 0;
      for (int i = 0; i < 10; i++) if (macAddresses[i] != "") numMACs++;
      int maxTop = max(0, numMACs - maxVisible);
      topIndex = min(topIndex + 1, maxTop);
      needRedraw = true;
    }

    if (needRedraw) {
      // Header
      M5.Display.fillRect(0, 0, 320, topY, TFT_BLACK);
      M5.Display.setTextColor(TFT_CYAN, TFT_BLACK);
      M5.Display.setCursor(5, 3);
      int numMACs = 0;
      for (int i = 0; i < 10; i++) if (macAddresses[i] != "") numMACs++;
      M5.Display.printf("Connected MACs (%d)", numMACs);

      // List
      M5.Display.fillRect(0, topY, 320, listH, TFT_BLACK);
      M5.Display.setTextColor(menuTextUnFocusedColor, TFT_BLACK);
      for (int v = 0; v < maxVisible; v++) {
        int idx = topIndex + v;
        if (idx >= 10 || macAddresses[idx] == "") break;
        M5.Display.setCursor(10, topY + v * lineHeight);
        M5.Display.println(macAddresses[idx]);
      }

      // Ticker
      M5.Display.fillRect(0, 240 - tickerH, 320, tickerH, TFT_BLACK);
      if (ticker.length() > 0 && millis() < tickerUntil) {
        M5.Display.setTextColor(TFT_GREEN, TFT_BLACK);
        M5.Display.setCursor(5, 240 - tickerH + 2);
        M5.Display.println(ticker);
      }

      M5.Display.display();
      needRedraw = false;
    }
    delay(20);
  }
}

