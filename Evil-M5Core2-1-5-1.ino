    html += "xhr.upload.onprogress=function(e){if(e.lengthComputable){p.value=Math.floor(e.loaded/e.total*100);s.textContent='Uploading '+p.value+'%';}};";
    html += "xhr.onload=function(){s.textContent='Upload complete';window.location='/dd-list';};";
    html += "xhr.onerror=function(){s.textContent='Upload failed';};";
    html += "var fd=new FormData();fd.append('data',f,f.name);xhr.send(fd);}</script>";
    html += "</div></body></html>";
    server.send(200, "text/html", html);
  });

  server.on("/dd-list", HTTP_GET, []() {
    File dir = SD.open(DD_BASE);
    if (!dir || !dir.isDirectory()) { server.send(500, "text/plain", "SD not ready"); return; }
    String html = "<!doctype html><html><head><meta charset='utf-8'><meta name='viewport' content='width=device-width,initial-scale=1'>";
    html += "<title>Deposits</title><style>body{background:#0a0a0a;color:#e0e0e0;font-family:monospace;margin:20px;}";
    html += "h3{color:#ff00aa;}a{color:#00b7ff;}table{width:100%;border-collapse:collapse;margin-top:10px;}";
    html += "th,td{text-align:left;padding:6px;border-bottom:1px solid #222;}th{color:#0ff;}</style></head><body>";
    html += "<h3>Uploaded Files</h3><table><tr><th>Name</th><th>Size</th></tr>";
    while (true) {
      File f = dir.openNextFile(); if (!f) break;
      if (!f.isDirectory()) {
        String base = f.name(); int p = base.lastIndexOf('/'); if (p >= 0) base = base.substring(p + 1);
        unsigned long sz = f.size(); String sizeStr;
        if (sz > 1000000) sizeStr = String((float)sz / 1000000.0, 2) + " MB";
        else if (sz > 1000) sizeStr = String((float)sz / 1000.0, 1) + " KB";
        else sizeStr = String(sz) + " B";
        html += "<tr><td><a href='/dd-get?f=" + ddUrlEncode(base) + "'>" + ddHtmlEscape(base) + "</a></td><td>" + sizeStr + "</td></tr>";
      }
      f.close();
    }
    dir.close();
    html += "</table><p><a href='/'>Back</a></p></body></html>";
    server.send(200, "text/html", html);
  });

  server.on("/dd-get", HTTP_GET, []() {
    if (!server.hasArg("f")) { server.send(400, "text/plain", "Missing f"); return; }
    String f = ddSafeName(server.arg("f"));
    String path = String(DD_BASE) + "/" + f;
    if (!SD.exists(path)) { server.send(404, "text/plain", "Not found"); return; }
    File file = SD.open(path, FILE_READ);
    if (!file) { server.send(500, "text/plain", "Failed to open"); return; }
    size_t fileSize = file.size();
    server.sendHeader("Content-Disposition", "attachment; filename=\"" + f + "\"");
    server.streamFile(file, ddMimeFromExt(f));
    file.close();
    ddDownloadsCount++;
    ddBytesOut += fileSize;
  });

  server.on("/dd-note", HTTP_POST, []() {
    String msg = server.arg("msg"); msg.trim();
    if (!SD.exists(DD_BASE)) SD.mkdir(DD_BASE);
    if (msg.length() > 0) {
      File notes = SD.open(String(DD_BASE) + "/notes.txt", FILE_APPEND);
      if (notes) { notes.println(msg); notes.close(); ddNotesCount++; }
    }
    server.sendHeader("Location", "/dd-list", true);
    server.send(302, "text/plain", "");
  });

  server.on("/dd-upload", HTTP_POST, []() { server.send(200, "text/plain", "OK"); }, handleDeadDropUpload);

  server.on("/generate_204", HTTP_GET, []() { server.send(200, "text/plain", "OK"); });
  server.on("/gen_204", HTTP_GET, []() { server.send(200, "text/plain", "OK"); });
  server.on("/hotspot-detect.html", HTTP_GET, []() { server.send(200, "text/html", "<html><head><title>Success</title></head><body>Success</body></html>"); });
  server.on("/ncsi.txt", HTTP_GET, []() { server.send(200, "text/plain", "Microsoft NCSI"); });
  server.on("/connecttest.txt", HTTP_GET, []() { server.send(200, "text/plain", "Microsoft Connect Test"); });
  server.on("/favicon.ico", HTTP_GET, []() { server.send(204); });
  server.onNotFound([]() { server.sendHeader("Location", "/", true); server.send(302, "text/plain", ""); });
}

void WifiDeadDrop() {
  dnsServer.stop();
  server.stop();
  isOperationInProgress = true;

  if (!SD.exists(DD_BASE)) SD.mkdir(DD_BASE);

  char ssidBuf[64];
  strncpy(ssidBuf, clonedSSID.c_str(), sizeof(ssidBuf) - 1);
  ssidBuf[sizeof(ssidBuf) - 1] = '\0';

  WiFi.mode(WIFI_MODE_AP);
  WiFi.softAP(ssidBuf, nullptr, 1, false, 10);
  IPAddress ipAP = WiFi.softAPIP();
  esp_wifi_set_ps(WIFI_PS_NONE);

  dnsServer.start(53, "*", ipAP);
  setupDeadDropRoutesSync();
  server.begin();

  ddActive = true;
  ddUploadsCount = 0; ddDownloadsCount = 0; ddNotesCount = 0;
  ddBytesIn = 0; ddBytesOut = 0;

  // Dashboard init
  memset(ddClientsHist, 0, sizeof(ddClientsHist));
  memset(ddInHist, 0, sizeof(ddInHist));
  memset(ddOutHist, 0, sizeof(ddOutHist));
  ddHistHead = 0;
  uiLastClients = -1; uiLastUp = ~0UL; uiLastDown = ~0UL; uiLastFiles = -1;
  ddLastBytesIn = 0; ddLastBytesOut = 0; ddLastTickMs = millis();

  ddDashboardInit(ssidBuf, ipAP.toString());

  while (ddActive) {
    kpSafeUpdate();
    dnsServer.processNextRequest();
    server.handleClient();

    if (kp(KEY_ENTER)) {
      ddActive = false;
      break;
    }

    // Update dashboard every 400ms
    unsigned long now = millis();
    if (now - ddLastTickMs >= 400) {
      unsigned long tickMs = now - ddLastTickMs;
      ddLastTickMs = now;

      int clients = WiFi.softAPgetStationNum();
      int files = ddCountFiles();

      unsigned long inDelta  = ddBytesIn  - ddLastBytesIn;
      unsigned long outDelta = ddBytesOut - ddLastBytesOut;
      ddLastBytesIn  = ddBytesIn;
      ddLastBytesOut = ddBytesOut;

      unsigned long inKBs  = (tickMs > 0) ? (inDelta  * 1000UL) / (tickMs * 1024UL) : 0;
      unsigned long outKBs = (tickMs > 0) ? (outDelta * 1000UL) / (tickMs * 1024UL) : 0;

      ddUpdateTileClients(clients);
      ddUpdateTileUploads(ddUploadsCount);
      ddUpdateTileDownloads(ddDownloadsCount);
      ddUpdateTileFiles(files);
      ddUpdateTileIO(inKBs, outKBs);

      uint8_t clientsScaled = (clients > 10) ? 100 : (uint8_t)(clients * 10);
      if (inKBs  > 200) inKBs  = 200;
      if (outKBs > 200) outKBs = 200;
      uint8_t inScaled  = (uint8_t)((inKBs  * 100UL) / 200UL);
      uint8_t outScaled = (uint8_t)((outKBs * 100UL) / 200UL);

      ddPushHistory(clientsScaled, inScaled, outScaled);
    }

    delay(1);
  }

  dnsServer.stop();
  server.stop();
  WiFi.softAPdisconnect(true);
  WiFi.mode(WIFI_MODE_APSTA);
  isOperationInProgress = false;
  waitAndReturnToMenu("Dead Drop stopped");
}

