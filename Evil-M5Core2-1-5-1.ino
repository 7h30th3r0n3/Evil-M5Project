// true  => launch viewer
// false => back to parent menu
bool runMenu() {
  // No streams -> wait for exit
  if (streamCount() == 0) {
    M5.Display.fillScreen(TFT_BLACK);
    uiText(2, 2, "MJPEG Viewer - MENU", TFT_CYAN);
    uiText(2, 18, "No streams. Check SD:/evil/CCTV/CCTV_live.txt", TFT_RED);
    uiText(2, 222, "B=Back", TFT_YELLOW);
    while (true) {
      kpSafeUpdate();
      if (kp(KEY_ENTER)) return false;
      delay(20);
    }
  }

  if (g_sel_stream >= streamCount()) g_sel_stream = 0;

  // Build stream names
  std::vector<String> streamNames;
  for (int i = 0; i < streamCount(); i++) {
    streamNames.push_back(String(i + 1) + "/" + String(streamCount()) + " " + g_streams[i].name);
  }

  // Build resolution names
  std::vector<String> resNames;
  for (int i = 0; i < RES_COUNT; i++) {
    resNames.push_back(String(RES_LIST[i]));
  }

  // Build compression values
  std::vector<String> compValues;
  for (int c = COMP_MIN; c <= COMP_MAX; c += 5) {
    compValues.push_back(String(c));
  }

  std::vector<FieldOption> fields = {
    {"Stream",      streamNames, g_sel_stream},
    {"Resolution",  resNames,    g_sel_res_idx},
    {"Compression", compValues,  g_sel_comp / 5}
  };

  int result = fieldOptionsMenu("MJPEG Viewer - MENU", fields, {"LAUNCH"});

  // Apply selections back
  g_sel_stream  = fields[0].currentIndex;
  g_sel_res_idx = fields[1].currentIndex;
  g_sel_comp    = fields[2].currentIndex * 5;

  if (result == 0) return true;  // LAUNCH
  return false;                  // BACK
}



// ---------- MJPEG VIEWER (timeouts 5s, sans goto) ----------
bool mjpegViewerFS(const char* url, fs::FS& fs, const char* pathA, const char* pathB) {
  // true -> revenir au menu ; false -> changer de flux (switch interne)
  UrlParts up;
  if (!parseUrl(String(url), up) || up.https) return true;

  bool exitToMenu = false; // BtnB = exit
  int  switchDelta = 0;    // -1 / +1 pour changer de flux

  static const int MAX_CONNECT_RETRIES = 3;

  while (!exitToMenu && switchDelta == 0) {
    kpSafeUpdate(); kpSafeUpdate();

    WiFiClient client;
    client.setTimeout(1);

    // statut discret sous la barre
    M5.Display.fillRect(0, TOPBAR_H, SCREEN_W, 10, TFT_BLACK);
    uiText(2, TOPBAR_H, "Connexion flux...", TFT_WHITE);

    // ---- TCP connect with retry limit ----
    uint32_t ready_deadline = millis() + STREAM_READY_TIMEOUT_MS;
    bool connected = false;
    for (int attempt = 0; attempt < MAX_CONNECT_RETRIES; ++attempt) {
      kpSafeUpdate();
      if (kp(KEY_ENTER)) { exitToMenu = true; break; }
      if (kp(',')) { switchDelta = -1; break; }
      if (kp('/')) { switchDelta = +1; break; }

      char msg[48];
      snprintf(msg, sizeof(msg), "Connexion %d/%d ...", attempt + 1, MAX_CONNECT_RETRIES);
      M5.Display.fillRect(0, TOPBAR_H, SCREEN_W, 10, TFT_BLACK);
      uiText(2, TOPBAR_H, msg, TFT_WHITE);

      if (client.connect(up.host.c_str(), up.port, CONNECT_TO_MS)) {
        connected = true;
        break;
      }
      delay(200);
    }
    if (exitToMenu || switchDelta != 0) break;
    if (!connected) {
      uiText(2, TOPBAR_H, "Connexion echouee -> menu", TFT_RED);
      delay(1200);
      return true;
    }

    // ---- HTTP GET ----
    String req;
    req += "GET " + up.path + " HTTP/1.1\r\n";
    req += "Host: " + up.host + ":" + String(up.port) + "\r\n";
    req += "User-Agent: M5Core2-MJPEG\r\n";
    req += "Accept: multipart/x-mixed-replace, image/jpeg\r\n";
    req += "Connection: keep-alive\r\n\r\n";
    client.print(req);

    char line[768];
    bool reconnect = false;

    // ---- Status line (deadline 5s) ----
    bool haveStatus = false;
    while (!haveStatus) {
      if (readLineCCTV(client, line, sizeof(line)) > 0) {
        haveStatus = true;
        break;
      }
      if (millis() > ready_deadline) {
        uiText(2, TOPBAR_H, "Timeout 5s (status)", TFT_RED);
        reconnect = true;
        break;
      }
      // clavier pendant attente
      kpSafeUpdate(); kpSafeUpdate();
      if (kp(KEY_ENTER)) {
        client.stop();
        return true;
      }
      if (kp(',')) {
        switchDelta = -1;
        client.stop();
        break;
      }
      if (kp('/')) {
        switchDelta = +1;
        client.stop();
        break;
      }
      delay(5);
    }
    if (!reconnect) {
      if (!strncmp(line, "HTTP/1.1 200", 12) || !strncmp(line, "HTTP/1.0 200", 12)) {
        // OK
      } else {
        // Erreur HTTP => retour menu direct
        client.stop();
        String statusLine = String(line);
        statusLine.trim();
        M5.Display.fillRect(0, TOPBAR_H, SCREEN_W, 10, TFT_BLACK);
        uiText(2, TOPBAR_H, (statusLine + " -> retour menu").c_str(), TFT_RED);
        delay(1200);
        return true;
      }
    }
    if (reconnect) {
      client.stop();
      M5.Display.fillRect(0, TOPBAR_H, SCREEN_W, 10, TFT_BLACK);
      uiText(2, TOPBAR_H, "Reconnexion...", TFT_YELLOW);
      delay(250);
      continue;
    }

    // ---- Headers (deadline 5s) ----
    String boundary, contentTypeSeen;
    while (true) {
      int n = readLineCCTV(client, line, sizeof(line));
      if (n > 0) {
        String hLow = String(line); hLow.toLowerCase();
        if (hLow.startsWith("content-type:")) {
          contentTypeSeen = String(line);
          String low = contentTypeSeen; low.toLowerCase();
          int p = low.indexOf("boundary=");
          if (p >= 0) {
            String val = contentTypeSeen.substring(p + 9);
            int sc = val.indexOf(';'); if (sc >= 0) val = val.substring(0, sc);
            val.trim();
            if (val.startsWith("\"") && val.endsWith("\"") && val.length() >= 2) val = val.substring(1, val.length() - 1);
            if (!val.startsWith("--")) val = "--" + val;
            boundary = val;
          }
        }
      } else {
        if (client.available() == 0) {
          if (millis() > ready_deadline) {
            uiText(2, TOPBAR_H, "Timeout 5s (headers)", TFT_RED);
            reconnect = true;
          } else {
            // clavier pendant attente
            kpSafeUpdate(); kpSafeUpdate();
            if (kp(KEY_ENTER)) {
              client.stop();
              return true;
            }
            if (kp(',')) {
              switchDelta = -1;
              client.stop();
              break;
            }
            if (kp('/')) {
              switchDelta = +1;
              client.stop();
              break;
            }
            delay(5);
            continue;
          }
        }
        break; // data dispo -> fin headers
      }
      if (!line[0]) break; // blank line -> fin headers
    }
    if (reconnect) {
      client.stop();
      M5.Display.fillRect(0, TOPBAR_H, SCREEN_W, 10, TFT_BLACK);
      uiText(2, TOPBAR_H, "Reconnexion...", TFT_YELLOW);
      delay(250);
      continue;
    }

    // ---- Sniff boundary si manquant (deadline 5s) ----
    bool alreadySyncedFirstPart = false;
    if (!boundary.length()) {
      while (true) {
        int n = readLineCCTV(client, line, sizeof(line));
        if (n > 0) {
          if (line[0] == '-' && line[1] == '-') {
            boundary = String(line);
            boundary.trim();
            alreadySyncedFirstPart = true;
            break;
          }
        } else {
          if (millis() > ready_deadline) {
            uiText(2, TOPBAR_H, "Timeout 5s (boundary)", TFT_RED);
            reconnect = true;
            break;
          }
          // clavier pendant attente
          kpSafeUpdate(); kpSafeUpdate();
          if (kp(KEY_ENTER)) {
            client.stop();
            return true;
          }
          if (kp(',')) {
            switchDelta = -1;
            client.stop();
            break;
          }
          if (kp('/')) {
            switchDelta = +1;
            client.stop();
            break;
          }
          delay(5);
        }
      }
    }
    if (reconnect) {
      client.stop();
      M5.Display.fillRect(0, TOPBAR_H, SCREEN_W, 10, TFT_BLACK);
      uiText(2, TOPBAR_H, "Reconnexion...", TFT_YELLOW);
      delay(250);
      continue;
    }

    // Nettoie la zone "statut"
    M5.Display.fillRect(0, TOPBAR_H, SCREEN_W, 10, TFT_BLACK);

    // FPS state & topbar
    uint32_t fpsT0 = millis();
    uint32_t fpsFrames = 0;
    float    lastFPS = 0.0f;
    String left = g_streams[g_sel_stream].name + "  " + RES_LIST[g_sel_res_idx] + "  c=" + String(g_sel_comp);
    drawTopBar(left, lastFPS);

    bool useA = true;
    uint32_t lastDataMs = millis();

    // === boucle frames ===
    while (!exitToMenu && switchDelta == 0) {
      kpSafeUpdate();
      handleDnsRequestSerial();  // maintain WebUI Navigator stream

      bool leftKey  = kp(',');
      bool rightKey = kp('/');

      if (kp(KEY_ENTER)) {
        exitToMenu = true;
        break;
      }
      if (leftKey)  {
        switchDelta = -1;
        break;
      }
      if (rightKey) {
        switchDelta = +1;
        break;
      }

      // No-data watchdog
      if (millis() - lastDataMs > STREAM_NO_DATA_TIMEOUT_MS) {
        uiText(2, TOPBAR_H, "No data 5s -> reconnect", TFT_YELLOW);
        reconnect = true;
        break;
      }

      // sync boundary
      bool synced = alreadySyncedFirstPart; alreadySyncedFirstPart = false;
      if (!synced) {
        while (true) {
          int n = readLineCCTV(client, line, sizeof(line));
          if (n <= 0) {
            if (client.available() == 0) break;
            else {
              synced = true;
              lastDataMs = millis();
              break;
            }
          }
          if (String(line).startsWith(boundary)) {
            synced = true;
            lastDataMs = millis();
            break;
          }
        }
        if (!synced) {
          reconnect = true;
          break;
        }
      }

      // headers part
      size_t contentLen = 0; bool haveLen = false; bool headerEnd = false;
      while (true) {
        int n = readLineCCTV(client, line, sizeof(line));
        if (n <= 0) {
          if (client.available() > 0) headerEnd = true;
          break;
        }
        lastDataMs = millis();
        if (String(line).startsWith(boundary)) continue;
        if (!line[0]) {
          headerEnd = true;
          break;
        }
        String hl = String(line); hl.toLowerCase();
        if (hl.startsWith("content-length:")) {
          contentLen = hl.substring(15).toInt();
          haveLen = contentLen > 0;
        }
      }
      if (!headerEnd) {
        reconnect = true;
        break;
      }

      // PSRAM target buffer
      uint8_t* dstBuf = useA ? psramBufA : psramBufB;
      size_t dstBufMax = PSRAM_BUF_SIZE;
      useA = !useA;

      bool ok = true; size_t totalWritten = 0;

      if (psramBufferingAvailable && dstBuf) {
        // === PSRAM fast path ===
        if (haveLen && contentLen > 0) {
          if (contentLen > dstBufMax) { reconnect = true; break; }
          size_t remain = contentLen;
          while (remain > 0) {
            size_t toRead = (remain > PSRAM_IO_CHUNK) ? PSRAM_IO_CHUNK : remain;
            size_t got = readN(client, dstBuf + totalWritten, toRead, READ_CHUNK_DEADLINE_MS);
            if (got == 0) { ok = false; break; }
            lastDataMs = millis();
            remain -= got; totalWritten += got;
          }
        } else {
          bool lastFF = false; uint32_t waitStart = millis();
          bool eoiFound = false;
          while (!eoiFound) {
            int avail = client.available();
            int want = (avail > 0) ? min(avail, (int)IO_CHUNK) : 1;
            if (totalWritten + want > dstBufMax) { ok = false; break; }
            int r = client.read(dstBuf + totalWritten, want);
            if (r <= 0) {
              if (millis() - waitStart > READ_CHUNK_DEADLINE_MS) { ok = false; break; }
              delay(1); continue;
            }
            waitStart = millis(); lastDataMs = millis();
            for (int i = 0; i < r; ++i) {
              uint8_t b = dstBuf[totalWritten + i];
              if (lastFF && b == 0xD9) {
                totalWritten += i + 1;
                eoiFound = true;
                break;
              }
              lastFF = (b == 0xFF);
            }
            if (!eoiFound) totalWritten += r;
          }
        }
        if (!ok || totalWritten < 32) { reconnect = true; break; }
        drawScaledJpgFromMem(dstBuf, totalWritten);
      } else {
        // === SD fallback path ===
        const char* filepath = useA ? pathA : pathB;
        File f = fs.open(filepath, FILE_WRITE);
        if (!f) { reconnect = true; break; }
        static uint8_t iobuf[IO_CHUNK];
        if (haveLen && contentLen > 0) {
          size_t remain = contentLen;
          while (remain > 0) {
            size_t toRead = (remain > IO_CHUNK) ? IO_CHUNK : remain;
            size_t got = readN(client, iobuf, toRead, READ_CHUNK_DEADLINE_MS);
            if (got == 0) { ok = false; break; }
            lastDataMs = millis();
            if (f.write(iobuf, got) != got) { ok = false; break; }
            remain -= got; totalWritten += got;
          }
        } else {
          bool lastFF = false; uint32_t waitStart = millis();
          while (true) {
            int avail = client.available();
            int want = (avail > 0) ? min(avail, (int)IO_CHUNK) : 1;
            int r = client.read(iobuf, want);
            if (r <= 0) {
              if (millis() - waitStart > READ_CHUNK_DEADLINE_MS) { ok = false; break; }
              delay(1); continue;
            }
            waitStart = millis(); lastDataMs = millis();
            for (int i = 0; i < r; ++i) {
              uint8_t b = iobuf[i];
              if (f.write(&b, 1) != 1) { ok = false; break; }
              totalWritten++;
              if (lastFF && b == 0xD9) { i = r; break; }
              lastFF = (b == 0xFF);
            }
            if (!ok) break;
          }
        }
        f.close();
        if (!ok || totalWritten < 32) { reconnect = true; break; }
        drawScaledJpg(fs, filepath);
      }

      // FPS stable (maj 1x/s)
      fpsFrames++;
      uint32_t now = millis();
      if (now - fpsT0 >= 1000) {
        lastFPS = fpsFrames * 1000.0f / (float)(now - fpsT0);
        fpsFrames = 0; fpsT0 = now;
        drawTopBar(left, lastFPS);
      }
    } // frames

    client.stop();

    if (reconnect && !exitToMenu && switchDelta == 0) {
      // BtnB pendant reconnexion
      kpSafeUpdate(); kpSafeUpdate();
      if (kp(KEY_ENTER)) {
        return true;
      }
      M5.Display.fillRect(0, TOPBAR_H, SCREEN_W, 10, TFT_BLACK);
      uiText(2, TOPBAR_H, "Reconnexion...", TFT_YELLOW);

      for (uint16_t t = 0; t < 250; t += 20) {
        delay(20);
        kpSafeUpdate(); kpSafeUpdate();
        if (kp(KEY_ENTER)) {
          return true;
        }
      }
      continue;
    }

  } // while session

  if (switchDelta != 0) {
    if (streamCount() > 0)
      g_sel_stream = (g_sel_stream + switchDelta + streamCount()) % streamCount();
    return false; // relancer viewer direct (sans repasser par menu)
  }
  return true; // retour menu
}



void runCCTV_MJPEGViewer() {
  if (WiFi.localIP().toString() == "0.0.0.0") {
    waitAndReturnToMenu("Not connected...");
    return;
  }
  enterDebounce();
  M5.Display.setTextSize(1);

  // Allocate PSRAM buffers for fast frame buffering
  if (!psramBufA && psramFound()) {
    psramBufA = (uint8_t*)ps_malloc(PSRAM_BUF_SIZE);
    psramBufB = (uint8_t*)ps_malloc(PSRAM_BUF_SIZE);
    psramBufferingAvailable = (psramBufA != nullptr && psramBufB != nullptr);
  }

  bool spiffs_ok = false;
  bool sd_ok = true;
  if (!sd_ok) spiffs_ok = SPIFFS.begin(true);
  if (!sd_ok && !spiffs_ok) {
    uiText(2, 2, "No SD/SPIFFS. Aborting.", TFT_RED);
    while (1) delay(1000);
  }
  if (sd_ok && !SD.exists(SD_TMP_DIR)) SD.mkdir(SD_TMP_DIR);

  // Charger la liste depuis SD; sinon fallback compilé
  if (!sd_ok || !loadStreamsFromFile(SD, CCTV_LIST_PATH)) {
    loadFallbackStreams();
  }

  fs::FS* pfs = sd_ok ? (fs::FS*)&SD : (fs::FS*)&SPIFFS;
  const char* fileA = sd_ok ? SD_FILE_A : SPIFFS_FILE_A;
  const char* fileB = sd_ok ? SD_FILE_B : SPIFFS_FILE_B;

  // Boucle globale : on reste ici tant que l'utilisateur ne remonte pas au menu parent
  while (!kp(KEY_ENTER)) {
    // --- Menu de sélection des flux ---
    bool launch = runMenu();   // true = launch, false = BtnB (retour parent)
    if (!launch) return;       // <- retour à scanCCTVCameras (menu parent)

    if (streamCount() == 0) return;

        // --- Boucle viewer : permettre switch +/- sans repasser par le menu de sélection ---
    while (true) {
      String url = buildUrl(g_streams[g_sel_stream], RES_LIST[g_sel_res_idx], g_sel_comp);
      bool backToMenu = mjpegViewerFS(url.c_str(), *pfs, fileA, fileB);
      if (backToMenu) {
        exitDebounce();
        break; // on sort uniquement si BtnB (menu)
      }
      // sinon mjpegViewerFS a changé g_sel_stream -> on relance direct sans break
    }
  }
}

