void uiDrawContent() {
  M5.Display.fillRect(0, UI_CONTENT_Y, UI_W, UI_CONTENT_H, TFT_BLACK);
  M5.Display.setTextSize(1);
  int linesToShow = min((int)_ui.lines.size(), uiMaxLines());
