void setCaptivePortalIP() {
  const char* choices[2] = { "192.168.4.1", "172.0.0.1" };
  int currentIndexLocal = portalIpIndex;
  bool selected = false;
  bool needDisplayUpdate = true;

  enterDebounce();

  while (!selected) {
    if (needDisplayUpdate) {
      M5.Display.clear();
      M5.Display.setCursor(5, 5);
      M5.Display.setTextSize(2);
      M5.Display.setTextColor(menuTextFocusedColor, menuBackgroundColor);
      M5.Display.println("Select Captive IP:");

      for (int i = 0; i < 2; i++) {
        if (i == currentIndexLocal) {
          M5.Display.setTextColor(menuTextFocusedColor);
        } else {
          M5.Display.setTextColor(menuTextUnFocusedColor, TFT_BLACK);
        }
        M5.Display.println(String("  ") + choices[i]);
      }
      M5.Display.setTextColor(TFT_YELLOW, TFT_BLACK);
      M5.Display.setCursor(2, 220);
      M5.Display.print("A=Up B=Select C=Down");
      needDisplayUpdate = false;
    }

    kpSafeUpdate();

    if (kp(KEY_BACKSPACE)) {
      currentIndexLocal = (currentIndexLocal - 1 + 2) % 2;
      needDisplayUpdate = true;
    } else if (kp('.')) {
      currentIndexLocal = (currentIndexLocal + 1) % 2;
      needDisplayUpdate = true;
    } else if (kp(KEY_ENTER)) {
      portalIpIndex = currentIndexLocal;
      saveConfigParameter("portal_ip_sel", portalIpIndex);
      waitAndReturnToMenu(String("Portal IP: ") + choices[portalIpIndex]);
      selected = true;
    }
    delay(50);
  }
}

void showSettingsMenu() {
  std::vector<std::pair<String, std::function<void()>>> options;

  bool continueSettingsMenu = true;

  while (continueSettingsMenu) {
    options.clear();

    options.push_back({"Brightness", brightness});
    options.push_back({soundOn ? "Sound Off" : "Sound On", []() {toggleSound();}});
    options.push_back({ledOn ? "LED Off" : "LED On", []() {toggleLED();}});
    options.push_back({"Set GPS Baudrate", []() {setGPSBaudrate();}});
    options.push_back({gpsPinsMode == 0 ? "GPS Pins: RX13/TX14" : "GPS Pins: RX32/TX33", []() {toggleGpsPinsMode();}});
    options.push_back({"Set Startup Image", setStartupImage});
    options.push_back({"Set Startup Volume", adjustVolume});
    options.push_back({"Set Startup Sound", setStartupSound});
    options.push_back({randomOn ? "Random startup Off" : "Random startup On", []() {toggleRandom();}});
    options.push_back({"Update DateTime", []() {updateDateTimeFromSD();}});

    // CPU Frequency selection
    options.push_back({"CPU Freq: " + String(getCpuFrequencyMhz()) + "MHz", []() {
      std::vector<String> freqs = {"80 MHz", "160 MHz", "240 MHz"};
      int sel = menuSelectList(freqs, "CPU Frequency");
      if (sel >= 0) {
        int mhz[] = {80, 160, 240};
        setCpuFrequencyMhz(mhz[sel]);
        saveConfigParameter("cpu_freq", mhz[sel]);
        waitAndReturnToMenu("CPU set to " + String(mhz[sel]) + " MHz");
      }
    }});

    // Boot auto toggle (separate)
    options.push_back({startAtBootFlag ? "Boot Auto: ON" : "Boot Auto: OFF", []() {
      startAtBootFlag = !startAtBootFlag;
      saveConfigParameter("startatboot", startAtBootFlag ? "true" : "false");
      waitAndReturnToMenu("Boot auto: " + String(startAtBootFlag ? "ON" : "OFF"));
    }});

    // Set auto function (case number)
    options.push_back({"Set Auto Function", []() {
      String caseStr = getUserInput("Menu case # (0-" + String(menuSize - 1) + "):");
      if (caseStr.length() > 0) {
        caseToStartAtBoot = caseStr.toInt();
        saveConfigParameter("casetostartatboot", String(caseToStartAtBoot));
        waitAndReturnToMenu("Auto case: " + String(caseToStartAtBoot));
      }
    }});

    // Set countdown
    options.push_back({"Set Boot Countdown", []() {
      String cdStr = getUserInput("Countdown secs (0-30):");
      if (cdStr.length() > 0) {
        bootCountdownSeconds = constrain(cdStr.toInt(), 0, 30);
        saveConfigParameter("boot_countdown", bootCountdownSeconds);
        waitAndReturnToMenu("Countdown: " + String(bootCountdownSeconds) + "s");
      }
    }});

    // Save Portal & SSID
    options.push_back({"Save Portal & SSID", []() {saveCurrentPortalAndSSID();}});

    // Change Portal IP
    options.push_back({"Change Portal IP", []() {setCaptivePortalIP();}});

    // Back
    options.push_back({"< Back", []() {}});

    loopOptions(options, false, true, "Settings");

    continueSettingsMenu = false;
  }
  exitDebounce();
  inMenu = true;
}

void applyGpsPinsForMode(int mode) {
  if (mode == 0) { gpsRxPin = 13; gpsTxPin = 14; gpsPinsMode = 0; }
  else if (mode == 1) { gpsRxPin = 32; gpsTxPin = 33; gpsPinsMode = 1; }
}

void toggleGpsPinsMode() {
  int newMode = (gpsPinsMode == 0) ? 1 : 0;
  applyGpsPinsForMode(newMode);
  saveConfigParameter("gps_pins_mode", gpsPinsMode);
  Serial2.end();
  Serial2.begin(baudrate_gps, SERIAL_8N1, gpsRxPin, gpsTxPin);
  waitAndReturnToMenu(gpsPinsMode == 0 ? "GPS Pins: RX13/TX14" : "GPS Pins: RX32/TX33");
}

void setGPSBaudrate() {
  // Liste des baudrates disponibles
  std::vector<int> baudrates = {9600, 19200, 115200};
  int currentBaudrateIndex = 0;
  bool baudrateSelected = false;

  const int maxDisplayItems = 3; // Tous les items peuvent être affichés simultanément
  bool needDisplayUpdate = true;

  enterDebounce();
  while (!baudrateSelected) {
    if (needDisplayUpdate) {
      M5.Display.clear();
      M5.Display.setCursor(0, 0);
      M5.Display.setTextColor(menuTextFocusedColor, menuBackgroundColor);
      M5.Display.println("Select GPS Baudrate:");

      for (int i = 0; i < baudrates.size(); i++) {
        if (i == currentBaudrateIndex) {
          M5.Display.setTextColor(menuTextFocusedColor); // Highlight selected item
        } else {
          M5.Display.setTextColor(menuTextUnFocusedColor, TFT_BLACK); // Normal text color
        }
        M5.Display.println(String(baudrates[i]));
      }

      needDisplayUpdate = false; // Reset the display update flag
    }

    kpSafeUpdate();


    // Navigation vers le haut
    if (kp(KEY_BACKSPACE)) {
      currentBaudrateIndex = (currentBaudrateIndex - 1 + baudrates.size()) % baudrates.size();
      needDisplayUpdate = true;
    }
    // Navigation vers le bas
    else if (kp('.')) {
      currentBaudrateIndex = (currentBaudrateIndex + 1) % baudrates.size();
      needDisplayUpdate = true;
    }
    // Sélectionner le baudrate
    else if (kp(KEY_ENTER)) {
      baudrate_gps = baudrates[currentBaudrateIndex];
      saveGPSBaudrateConfig(baudrate_gps);
      M5.Display.setTextColor(menuTextFocusedColor, menuBackgroundColor);
      M5.Display.fillScreen(menuBackgroundColor);
      M5.Display.setCursor(0, M5.Display.height() / 2);
      M5.Display.print("GPS Baudrate set to\n" + String(baudrate_gps));
      Serial2.end();
      Serial2.begin(baudrate_gps, SERIAL_8N1, gpsRxPin, gpsTxPin);
      delay(1000);
      baudrateSelected = true;
    }
    // Quitter sans sélectionner
    else if (kp(KEY_ENTER)) {
      baudrateSelected = true;
    }

    delay(150);  // Anti-bounce delay for key presses
  }
}

void saveGPSBaudrateConfig(int baudrate) {
  // Lire le contenu du fichier de configuration
  File file = SD.open(configFilePath, FILE_READ);
  String content = "";
  bool found = false;

  if (file) {
    while (file.available()) {
      String line = file.readStringUntil('\n');
      if (line.startsWith("baudrate_gps=")) {
        // Remplacer la ligne existante par la nouvelle valeur
        content += "baudrate_gps=" + String(baudrate) + "\n";
        found = true;
      } else {
        // Conserver les autres lignes
        content += line + "\n";
      }
    }
    file.close();
  }

  // Si la clé n'a pas été trouvée, l'ajouter à la fin
  if (!found) {
    content += "baudrate_gps=" + String(baudrate) + "\n";
  }

  // Réécrire tout le fichier de configuration
  file = SD.open(configFilePath, FILE_WRITE);
  if (file) {
    file.print(content);
    file.close();
  }
}



