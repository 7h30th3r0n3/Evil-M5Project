// BtnB = select character (or action), PWR = switch mode
// Also accepts input from BLE serial and USB serial in parallel (non-blocking).
String getUserInput(const String& prompt, bool isPassword, bool allowEmpty) {
  // Character sets for each mode
  static const char* MODE_LABELS[] = { "abc", "ABC", "123", "!@#", "CTL" };
  static const int   NUM_MODES = 5;
  static const char* CHARSETS[] = {
    "abcdefghijklmnopqrstuvwxyz .-_",   // abc (29 chars)
    "ABCDEFGHIJKLMNOPQRSTUVWXYZ .-_",   // ABC (29 chars)
    "0123456789.:/-_@#",                 // 123 (17 chars)
    "!@#$%^&*()+={}[]|\\<>?,;'\"~`",    // !@# (27 chars)
    nullptr                              // CTL (special actions)
  };
  // CTL mode actions
  static const char* CTL_LABELS[] = { "DEL", "CLEAR", "DONE", "CANCEL" };
  static const int   NUM_CTL = 4;

  String input = "";
  int mode = 0;        // current charset mode index
  int charIdx = 0;     // cursor position within current charset
  bool needRedraw = true;

  // Screen layout constants for 320x240
  const int SCR_W = 320;
  const int SCR_H = 240;
  const int PROMPT_Y = 4;
  const int INPUT_Y  = 28;
  const int CHAR_Y   = 80;   // character selector row
  const int CHAR_H   = 30;   // height of selector area
  const int INFO_Y   = 130;  // mode info line
  const int HELP_Y   = 215;  // bottom help line
  const int MAX_VISIBLE_CHARS = 18; // chars visible in selector at once

  while (true) {
    // ── Non-blocking serial input (BLE + USB) ──
    if (ESP_BT.available()) {
      String bleIn = ESP_BT.readStringUntil('\n');
      bleIn.trim();
      if (bleIn.length() > 0) {
        sendBLE("Input received: " + bleIn);
        return bleIn;
      }
    }
    if (Serial.available()) {
      String serIn = Serial.readStringUntil('\n');
      serIn.trim();
      if (serIn.length() > 0) return serIn;
    }

    // ── Draw UI ──
    if (needRedraw) {
      M5.Display.fillScreen(TFT_BLACK);

      // Prompt
      M5.Display.setTextSize(2);
      M5.Display.setTextColor(TFT_YELLOW, TFT_BLACK);
      M5.Display.setCursor(5, PROMPT_Y);
      M5.Display.print(prompt);

      // Current input text (show last ~26 chars if too long)
      M5.Display.setTextSize(2);
      M5.Display.setTextColor(TFT_GREEN, TFT_BLACK);
      M5.Display.setCursor(5, INPUT_Y);
      String displayInput = isPassword ? String('*').substring(0,0) : input;
      if (isPassword) {
        displayInput = "";
        for (int i = 0; i < (int)input.length(); i++) displayInput += '*';
      }
      const int maxShow = 26;
      if ((int)displayInput.length() > maxShow) {
        displayInput = "..." + displayInput.substring(displayInput.length() - (maxShow - 3));
      }
      M5.Display.print("> ");
      M5.Display.print(displayInput);
      M5.Display.print("_");

      // ── Character selector row ──
      M5.Display.setTextSize(2);
      if (mode < 4) {
        // Normal charset mode
        const char* cs = CHARSETS[mode];
        int csLen = strlen(cs);
        if (charIdx >= csLen) charIdx = csLen - 1;
        if (charIdx < 0) charIdx = 0;

        // Calculate visible window centered on charIdx
        int halfVis = MAX_VISIBLE_CHARS / 2;
        int startC = charIdx - halfVis;
        if (startC < 0) startC = 0;
        if (startC + MAX_VISIBLE_CHARS > csLen) startC = max(0, csLen - MAX_VISIBLE_CHARS);
        int endC = min(csLen, startC + MAX_VISIBLE_CHARS);

        int xPos = 10;
        for (int i = startC; i < endC; i++) {
          char ch = cs[i];
          String disp = String(ch);
          if (ch == ' ') disp = "SP";

          if (i == charIdx) {
            // Highlight selected char
            int boxW = (disp.length() == 2) ? 28 : 16;
            M5.Display.fillRect(xPos - 2, CHAR_Y - 2, boxW, CHAR_H, TFT_NAVY);
            M5.Display.setTextColor(TFT_WHITE, TFT_NAVY);
          } else {
            M5.Display.setTextColor(TFT_LIGHTGREY, TFT_BLACK);
          }
          M5.Display.setCursor(xPos, CHAR_Y + 4);
          M5.Display.print(disp);
          xPos += (disp.length() == 2) ? 30 : 18;
        }

        // Scroll arrows
        M5.Display.setTextColor(TFT_DARKGREY, TFT_BLACK);
        if (startC > 0) {
          M5.Display.setCursor(0, CHAR_Y + 4);
          M5.Display.print("<");
        }
        if (endC < csLen) {
          M5.Display.setCursor(SCR_W - 12, CHAR_Y + 4);
          M5.Display.print(">");
        }
      } else {
        // CTL mode - show action labels
        int xPos = 15;
        for (int i = 0; i < NUM_CTL; i++) {
          if (i == charIdx) {
            int bw = strlen(CTL_LABELS[i]) * 12 + 8;
            M5.Display.fillRect(xPos - 4, CHAR_Y - 2, bw, CHAR_H, TFT_NAVY);
            M5.Display.setTextColor(TFT_WHITE, TFT_NAVY);
          } else {
            M5.Display.setTextColor(TFT_LIGHTGREY, TFT_BLACK);
          }
          M5.Display.setCursor(xPos, CHAR_Y + 4);
          M5.Display.print(CTL_LABELS[i]);
          xPos += strlen(CTL_LABELS[i]) * 12 + 16;
        }
      }

      // Mode indicator line
      M5.Display.setTextSize(2);
      M5.Display.setCursor(5, INFO_Y);
      M5.Display.setTextColor(TFT_DARKGREY, TFT_BLACK);
      M5.Display.print("Mode: ");
      for (int m = 0; m < NUM_MODES; m++) {
        if (m == mode) {
          M5.Display.setTextColor(TFT_CYAN, TFT_BLACK);
        } else {
          M5.Display.setTextColor(TFT_DARKGREY, TFT_BLACK);
        }
        M5.Display.print(MODE_LABELS[m]);
        if (m < NUM_MODES - 1) M5.Display.print(" ");
      }

      // Input length counter
      M5.Display.setTextSize(1);
      M5.Display.setTextColor(TFT_DARKGREY, TFT_BLACK);
      M5.Display.setCursor(SCR_W - 50, INPUT_Y + 4);
      M5.Display.print("[");
      M5.Display.print(input.length());
      M5.Display.print("]");

      // Bottom help line
      M5.Display.setTextSize(2);
      M5.Display.setTextColor(TFT_DARKGREY, TFT_BLACK);
      M5.Display.setCursor(5, HELP_Y);
      M5.Display.print("A=");
      M5.Display.setTextColor(TFT_WHITE, TFT_BLACK);
      M5.Display.print("<");
      M5.Display.setTextColor(TFT_DARKGREY, TFT_BLACK);
      M5.Display.print(" B=");
      M5.Display.setTextColor(TFT_WHITE, TFT_BLACK);
      M5.Display.print("SEL");
      M5.Display.setTextColor(TFT_DARKGREY, TFT_BLACK);
      M5.Display.print(" C=");
      M5.Display.setTextColor(TFT_WHITE, TFT_BLACK);
      M5.Display.print(">");
      M5.Display.setTextColor(TFT_DARKGREY, TFT_BLACK);
      M5.Display.print(" PWR=");
      M5.Display.setTextColor(TFT_CYAN, TFT_BLACK);
      M5.Display.print("Fn");

      M5.Display.display();
      needRedraw = false;
    }

    // ── Handle button input ──
    kpSafeUpdate();
    handleDnsRequestSerial();
    bool pwrClicked = M5.BtnPWR.wasClicked();  // capture PWR before kp() calls consume M5.update()

    // BtnA = move left
    if (kp(KEY_BACKSPACE)) {
      _kpA = false;
      charIdx--;
      int maxIdx = (mode < 4) ? (int)strlen(CHARSETS[mode]) - 1 : NUM_CTL - 1;
      if (charIdx < 0) charIdx = maxIdx; // wrap around
      needRedraw = true;
    }

    // BtnC = move right
    if (kp('.')) {
      _kpC = false;
      charIdx++;
      int maxIdx = (mode < 4) ? (int)strlen(CHARSETS[mode]) - 1 : NUM_CTL - 1;
      if (charIdx > maxIdx) charIdx = 0; // wrap around
      needRedraw = true;
    }

    // BtnB = select current char / execute CTL action
    if (kp(KEY_ENTER)) {
      _kpB = false;
      if (mode < 4) {
        // Insert character at end of input
        char selected = CHARSETS[mode][charIdx];
        input += selected;
        needRedraw = true;
      } else {
        // CTL mode actions
        switch (charIdx) {
          case 0: // DEL - delete last char
            if (input.length() > 0) input.remove(input.length() - 1);
            needRedraw = true;
            break;
          case 1: // CLEAR - clear all input
            input = "";
            needRedraw = true;
            break;
          case 2: // DONE - confirm and return
            if (allowEmpty || input.length() > 0) {
              enterDebounce();
              return input;
            }
            needRedraw = true;
            break;
          case 3: // CANCEL - return empty
            enterDebounce();
            return "";
        }
      }
    }

    // PWR = switch mode
    if (pwrClicked) {
      mode = (mode + 1) % NUM_MODES;
      // Clamp charIdx to new charset length
      int maxIdx = (mode < 4) ? (int)strlen(CHARSETS[mode]) - 1 : NUM_CTL - 1;
      if (charIdx > maxIdx) charIdx = 0;
      needRedraw = true;
    }

    // ── Web keyboard raw character input ──
    if (navPendingCharValid) {
      uint8_t ch = navPendingChar;
      navPendingCharValid = false;
      navPendingChar = 0;
      if (ch == 42) {
        // Backspace (Cardputer key code)
        if (input.length() > 0) input.remove(input.length() - 1);
        needRedraw = true;
      } else if (ch == 40) {
        // Enter (Cardputer key code) — confirm input
        if (allowEmpty || input.length() > 0) {
          enterDebounce();
          return input;
        }
      } else if (ch == 255) {
        // Fn — switch mode (same as PWR)
        mode = (mode + 1) % NUM_MODES;
        int maxIdx = (mode < 4) ? (int)strlen(CHARSETS[mode]) - 1 : NUM_CTL - 1;
        if (charIdx > maxIdx) charIdx = 0;
        needRedraw = true;
      } else if (ch >= 32 && ch <= 126) {
        // Printable ASCII — append directly
        input += (char)ch;
        needRedraw = true;
      }
      // Ignore other codes (Tab=43, Ctrl=128, Shift=129, Alt=130, Opt=0)
    }

    delay(30);
  }
}

