#include "freertos/FreeRTOS.h"
#include "freertos/task.h"

// Forward declarations for kp sticky cache (defined later with kpSafeUpdate)
extern bool _kpA, _kpB, _kpC;

void enterDebounce() {
  // Wait until BtnB is physically released (level check, not edge)
  delay(20);
  kpSafeUpdate();
  while (M5.BtnB.isPressed()) {
    kpSafeUpdate();
    delay(10);
  }
  // Clear sticky cache so the press doesn't leak to the next kp() call
  _kpB = false;
  _kpA = false;
  _kpC = false;
}

void backDebounce() {
  // Wait until BtnA/BtnC are physically released
  delay(20);
  kpSafeUpdate();
  while (M5.BtnC.isPressed() || M5.BtnA.isPressed()) {
    kpSafeUpdate();
    delay(10);
  }
  _kpA = false;
  _kpB = false;
  _kpC = false;
}

void exitDebounce() {
  delay(20);
  kpSafeUpdate();
  while (M5.BtnA.isPressed() || M5.BtnB.isPressed() || M5.BtnC.isPressed()) {
    kpSafeUpdate();
    delay(10);
  }
  _kpA = false;
  _kpB = false;
  _kpC = false;
}

void returnToMainMenu() {
  exitDebounce();
  inMenu = true;
  drawMenu();
}

struct FieldOption {
  String label;
  std::vector<String> values;
  int currentIndex;
};

// Returns: index of the selected action, or -1 for back
int fieldOptionsMenu(const String& title, std::vector<FieldOption>& fields,
                     const std::vector<String>& actionLabels = {"LAUNCH"}) {
  exitDebounce();
  int totalItems = (int)fields.size() + (int)actionLabels.size() + 1; // +1 for BACK
  int backIdx = totalItems - 1;
  int sel = 0;
  bool needRedraw = true;
  HoldRepeat holdA, holdC;

  while (true) {
    if (needRedraw) {
      M5.Display.fillScreen(TFT_BLACK);
      M5.Display.setTextSize(2);
      M5.Display.setTextColor(TFT_CYAN, TFT_BLACK);
      M5.Display.setCursor(4, 2);
      M5.Display.println(title);

      int y = 26;
      for (int i = 0; i < totalItems; i++) {
        bool isSel = (i == sel);
        uint16_t fg = isSel ? TFT_GREEN : TFT_WHITE;
        uint16_t bg = isSel ? 0x0320 : TFT_BLACK;
        if (isSel) M5.Display.fillRect(0, y - 2, 320, 20, bg);
        M5.Display.setTextColor(fg, bg);
        M5.Display.setCursor(4, y);

        if (i < (int)fields.size()) {
          M5.Display.print("> " + fields[i].label + ": [" +
                           fields[i].values[fields[i].currentIndex] + "]");
        } else if (i < (int)fields.size() + (int)actionLabels.size()) {
          M5.Display.print("> [" + actionLabels[i - (int)fields.size()] + "]");
        } else {
          M5.Display.print("> [BACK]");
        }
        y += 22;
      }

      M5.Display.fillRect(0, 220, 320, 20, TFT_BLACK);
      M5.Display.setTextSize(1);
      M5.Display.setTextColor(TFT_YELLOW, TFT_BLACK);
      M5.Display.setCursor(2, 222);
      M5.Display.print("A=Up B=OK C=Down PWR=Chg");
      needRedraw = false;
    }

    unsigned long now = millis();
    kpSafeUpdate();

    if (holdA.update(M5.BtnA.isPressed(), now)) {
      sel = (sel - 1 + totalItems) % totalItems;
      needRedraw = true;
    }
    if (holdC.update(M5.BtnC.isPressed(), now)) {
      sel = (sel + 1) % totalItems;
      needRedraw = true;
    }
    if (kp(KEY_ENTER)) {
      if (sel == backIdx) return -1;
      if (sel >= (int)fields.size()) return sel - (int)fields.size();
      // On a field: cycle value
      fields[sel].currentIndex = (fields[sel].currentIndex + 1) % (int)fields[sel].values.size();
      needRedraw = true;
    }
    if (M5.BtnPWR.wasClicked() && sel < (int)fields.size()) {
      fields[sel].currentIndex = (fields[sel].currentIndex + 1) % (int)fields[sel].values.size();
      needRedraw = true;
    }
    delay(8);
  }
}

