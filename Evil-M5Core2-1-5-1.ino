// menuSelectList() - Select from a list using Core2 buttons
int menuSelectList(const std::vector<String>& items, const char* title) {
  if (items.empty()) return -1;
  enterDebounce();

  int sel = 0;
  int top = 0;
  const int maxVisible = 8;
  bool redraw = true;
  HoldRepeat holdA, holdC;

  while (true) {
    kpSafeUpdate();
    
    if (redraw) {
      M5.Display.fillScreen(TFT_BLACK);
      M5.Display.setTextSize(2);
      M5.Display.setTextColor(TFT_GREEN, TFT_BLACK);
      M5.Display.setCursor(5, 2);
      M5.Display.println(title);
      
      M5.Display.setTextSize(2);
      for (int i = 0; i < maxVisible && (top + i) < (int)items.size(); i++) {
        int idx = top + i;
        if (idx == sel) {
          M5.Display.setTextColor(TFT_GREEN, TFT_NAVY);
        } else {
          M5.Display.setTextColor(TFT_WHITE, TFT_BLACK);
        }
        M5.Display.setCursor(5, 25 + i * 22);
        M5.Display.print(String(idx) + ": ");
        M5.Display.println(fitLeft(items[idx], 28));
      }
      
      M5.Display.setTextColor(TFT_DARKGREY, TFT_BLACK);
      M5.Display.setCursor(5, 220);
      M5.Display.print("A=Up B=Select C=Down PWR=Back");
      redraw = false;
    }

    unsigned long now = millis();
    if (holdC.update(M5.BtnC.isPressed(), now)) {
      sel = min(sel + 1, (int)items.size() - 1);
      if (sel >= top + maxVisible) top++;
      redraw = true;
    }
    if (holdA.update(M5.BtnA.isPressed(), now)) {
      if (sel > 0) {
        sel--;
        if (sel < top) top--;
        redraw = true;
      } else {
        return -1; // Cancel (top of list)
      }
    }
    if (kp(KEY_ENTER)) {
      return sel;
    }
    if (M5.BtnPWR.wasClicked()) {
      return -1; // PWR = cancel
    }

    delay(8);
  }
}

// menuSelectListArray() - Array version of menuSelectList
int menuSelectListArray(String *items, int count, const char *title) {
  std::vector<String> v;
  for (int i = 0; i < count; i++) v.push_back(items[i]);
  return menuSelectList(v, title);
}


