// ===== OPT-1/3: Buffered SD reads with dual-core prefetch =====
static const size_t CRACK_BUF_SIZE = 64 * 1024;

// Hardware memory barrier for ESP32 Xtensa dual-core cross-cache visibility
#define CRACK_MEM_BARRIER() __asm__ __volatile__("memw" ::: "memory")

struct CrackBufCtx {
  File *file;
  uint8_t *buf[2];            // Two 64KB PSRAM buffers (double-buffering)
  size_t bufSize[2];           // Valid bytes in each buffer
  size_t readPos;              // Read position in active buffer
  int activeIdx;               // Which buffer Core 0 reads from (0 or 1)
  volatile int fillIdx;        // Which buffer Core 1 should fill
  SemaphoreHandle_t fillSem;   // Signal Core 1 to start filling
  SemaphoreHandle_t doneSem;   // Signaled by prefetch task before exiting
  volatile bool fillReady;     // Inactive buffer is filled and ready
  volatile bool fileExhausted; // No more data in file
  volatile bool stopTask;      // Signal prefetch task to exit
  bool prefetchPending;        // Core 0 only: outstanding prefetch request
  TaskHandle_t taskHandle;     // Prefetch task handle
  uint32_t totalBytesRead;     // OPT-7: Manual position tracking
};

// Prefetch task running on Core 1 — reads next SD block while Core 0 hashes
void sdPrefetchTaskFn(void *param) {
  CrackBufCtx *ctx = (CrackBufCtx*)param;
  while (!ctx->stopTask) {
    if (xSemaphoreTake(ctx->fillSem, pdMS_TO_TICKS(50)) != pdTRUE) continue;
    if (ctx->stopTask) break;
    int idx = ctx->fillIdx;
    if (ctx->file->available()) {
      size_t n = ctx->file->read(ctx->buf[idx], CRACK_BUF_SIZE);
      ctx->bufSize[idx] = n;
      if (!ctx->file->available()) ctx->fileExhausted = true;
    } else {
      ctx->bufSize[idx] = 0;
      ctx->fileExhausted = true;
    }
    CRACK_MEM_BARRIER(); // Ensure bufSize/fileExhausted visible before fillReady
    ctx->fillReady = true;
  }
  // Unblock any spin-wait in crackBufReadLine before exiting
  ctx->fillReady = true;
  xSemaphoreGive(ctx->doneSem);
  vTaskDelete(NULL);
}

bool crackBufInit(CrackBufCtx *ctx, File &file) {
  ctx->file = &file;
  ctx->buf[0] = (uint8_t*)ps_malloc(CRACK_BUF_SIZE);
  ctx->buf[1] = (uint8_t*)ps_malloc(CRACK_BUF_SIZE);
  if (!ctx->buf[0] || !ctx->buf[1]) {
    if (ctx->buf[0]) free(ctx->buf[0]);
    if (ctx->buf[1]) free(ctx->buf[1]);
    return false;
  }
  // Read first block synchronously
  size_t n = file.read(ctx->buf[0], CRACK_BUF_SIZE);
  ctx->bufSize[0] = n;
  ctx->bufSize[1] = 0;
  ctx->activeIdx = 0;
  ctx->readPos = 0;
  ctx->totalBytesRead = 0;
  ctx->fillReady = false;
  ctx->fileExhausted = !file.available();
  ctx->stopTask = false;
  ctx->fillIdx = 1;
  ctx->prefetchPending = false;
  ctx->fillSem = xSemaphoreCreateBinary();
  ctx->doneSem = xSemaphoreCreateBinary();
  if (!ctx->fileExhausted) {
    // Start prefetch task on Core 1
    xTaskCreatePinnedToCore(sdPrefetchTaskFn, "SDpre", 4096, ctx, 1, &ctx->taskHandle, 1);
    xSemaphoreGive(ctx->fillSem); // Start first prefetch
    ctx->prefetchPending = true;
  } else {
    ctx->taskHandle = NULL;
  }
  return true;
}

// OPT-12: Read one line using memchr() block scan instead of byte-by-byte
int crackBufReadLine(CrackBufCtx *ctx, char *out, int maxLen) {
  int outPos = 0;
  while (true) {
    uint8_t *buf = ctx->buf[ctx->activeIdx];
    size_t size = ctx->bufSize[ctx->activeIdx];
    size_t remaining = size - ctx->readPos;

    if (remaining > 0) {
      uint8_t *nl = (uint8_t*)memchr(buf + ctx->readPos, '\n', remaining);
      if (nl) {
        size_t lineLen = nl - (buf + ctx->readPos);
        int copyLen = ((int)lineLen < maxLen - 1 - outPos) ? (int)lineLen : (maxLen - 1 - outPos);
        if (copyLen > 0) { memcpy(out + outPos, buf + ctx->readPos, copyLen); outPos += copyLen; }
        ctx->totalBytesRead += lineLen + 1;
        ctx->readPos += lineLen + 1;
        if (outPos > 0 && out[outPos - 1] == '\r') outPos--;
        out[outPos] = '\0';
        return outPos;
      }
      // No \n found — copy remainder and move to next buffer
      int copyLen = ((int)remaining < maxLen - 1 - outPos) ? (int)remaining : (maxLen - 1 - outPos);
      if (copyLen > 0) { memcpy(out + outPos, buf + ctx->readPos, copyLen); outPos += copyLen; }
      ctx->totalBytesRead += remaining;
      ctx->readPos = size;
    }
    // Active buffer exhausted — check if a prefetch is pending
    if (!ctx->prefetchPending) {
      // No more buffers coming (file fit in one buffer, or already exhausted)
      if (outPos > 0) { out[outPos] = '\0'; return outPos; }
      return -1;
    }
    // Wait for prefetch to complete
    while (!ctx->fillReady) {
      if (ctx->stopTask) {
        if (outPos > 0) { out[outPos] = '\0'; return outPos; }
        return -1;
      }
      vTaskDelay(1);
    }
    CRACK_MEM_BARRIER(); // Ensure bufSize/fileExhausted reads see Core 1's writes
    int newIdx = 1 - ctx->activeIdx;
    if (ctx->bufSize[newIdx] == 0) {
      ctx->prefetchPending = false;
      if (outPos > 0) { out[outPos] = '\0'; return outPos; }
      return -1;
    }
    ctx->activeIdx = newIdx;
    ctx->readPos = 0;
    ctx->fillReady = false;
    if (!ctx->fileExhausted) {
      ctx->fillIdx = 1 - ctx->activeIdx;
      xSemaphoreGive(ctx->fillSem);
      ctx->prefetchPending = true;
    } else {
      ctx->prefetchPending = false;
    }
  }
}

void crackBufFree(CrackBufCtx *ctx) {
  ctx->stopTask = true;
  if (ctx->taskHandle) {
    xSemaphoreGive(ctx->fillSem); // Wake task so it can exit
    xSemaphoreTake(ctx->doneSem, pdMS_TO_TICKS(2000)); // Wait for task exit
  }
  if (ctx->doneSem) vSemaphoreDelete(ctx->doneSem);
  if (ctx->fillSem) vSemaphoreDelete(ctx->fillSem);
  if (ctx->buf[0]) free(ctx->buf[0]);
  if (ctx->buf[1]) free(ctx->buf[1]);
}

// ===== OPT-14: Dual-core hash worker =====
#define CRACK_BATCH_SIZE 64

struct CrackWorkerCtx {
  // Shared params (constant for one user's crack session)
  const uint8_t *idbuf;
  size_t idlen;
  const uint8_t *msg;
  size_t msgLen;
  const uint8_t *ntProof;

  // Batch work
  char passwords[CRACK_BATCH_SIZE][65];
  int pwdLens[CRACK_BATCH_SIZE];
  int startIdx;
  int endIdx;
  int foundIdx;        // -1 if not found, else index of match

  // Sync
  TaskHandle_t taskHandle;
  volatile bool workReady;
  volatile bool workDone;
  volatile bool stopTask;
  SemaphoreHandle_t doneSem;
};

void hashWorkerTask(void *param) {
  CrackWorkerCtx *ctx = (CrackWorkerCtx*)param;
  while (true) {
    // Block until notified — yields CPU to IDLE task (prevents watchdog reset)
    ulTaskNotifyTake(pdTRUE, portMAX_DELAY);
    if (ctx->stopTask) break;
    CRACK_MEM_BARRIER();

    ctx->foundIdx = -1;
    for (int i = ctx->startIdx; i < ctx->endIdx; i++) {
      uint8_t nthash[16];
      ntlmHashFast(ctx->passwords[i], ctx->pwdLens[i], nthash);

      uint8_t resp[16];
      crackNTLMv2_attempt(nthash, ctx->idbuf, ctx->idlen,
                          ctx->msg, ctx->msgLen, resp);

      if (*(uint64_t*)resp == *(uint64_t*)ctx->ntProof &&
          *(uint64_t*)(resp+8) == *(uint64_t*)(ctx->ntProof+8)) {
        ctx->foundIdx = i;
        break;
      }
    }
    CRACK_MEM_BARRIER();
    ctx->workDone = true;
  }
  xSemaphoreGive(ctx->doneSem);
  vTaskDelete(NULL);
}

// ===== Crack NTLMv2 =====
void crackNTLMv2() {
  ensureFilesExist();

  File hf = SD.open("/evil/NTLM/ntlm_hashes.txt", FILE_READ);
  if (!hf) {
    Serial.println("[ERROR] Cannot open /evil/NTLM/ntlm_hashes.txt");
    waitAndReturnToMenu("Back To Main Menu");
    return;
  }

  if (hf.size() == 0) {
    Serial.println("[WARN] /NTLM/ntlm_hashes.txt is empty!");
    hf.close();

    M5.Display.fillScreen(TFT_BLACK);
    M5.Display.setCursor(20, 50);
    M5.Display.setTextSize(1);
    M5.Display.setTextColor(TFT_RED, TFT_BLACK);
    M5.Display.println("ntlm_hashes.txt is empty!");
    delay(2000);

    waitAndReturnToMenu("Back To Main Menu");
    return;
  }
  bool stopRequested = false;
  while (hf.available() && !stopRequested) {
    if (isBackspacePressed()) {
      stopRequested = true;
      break;
    }
    String line = hf.readStringUntil('\n');
    line.trim();
    if (line.length() < 10 || line.startsWith("-")) continue;

    Serial.println("=====================================");
    Serial.println("[INFO] Testing hash line: " + line);

    // Parse NTLMv2 line: user::domain:challenge:ntproof:blob
    int idx1 = line.indexOf("::");
    int idx2 = line.indexOf(":", idx1+2);
    int idx3 = line.indexOf(":", idx2+1);
    int idx4 = line.indexOf(":", idx3+1);
    if (idx1 < 0 || idx2 < 0 || idx3 < 0 || idx4 < 0) {
      Serial.println("[WARN] Invalid line format, skipping.");
      continue;
    }

    String user     = line.substring(0, idx1);
    String domain   = line.substring(idx1+2, idx2);
    String challHex = line.substring(idx2+1, idx3);
    String ntProofHex = line.substring(idx3+1, idx4);
    String blobHex  = line.substring(idx4+1);

    drawNTLMInitUser(user);

    uint8_t challenge[8];  hexToBytes(challHex, challenge, 8);
    uint8_t ntProof[16];   hexToBytes(ntProofHex, ntProof, 16);

    int blobLen = blobHex.length()/2;
    if (blobLen <= 0) { Serial.println("[WARN] Invalid blob, skipping."); continue; }
    uint8_t *blob = (uint8_t*)malloc(blobLen);
    hexToBytes(blobHex, blob, blobLen);

    // Pré-construire SC||Blob
    size_t msgLen = 8 + (size_t)blobLen;
    uint8_t *msg = (uint8_t*)malloc(msgLen);
    memcpy(msg, challenge, 8);
    memcpy(msg+8, blob, blobLen);

    // Pré-construire UTF16LE(UPPER(user)+domain) — garder le '$' s’il existe
    String upUser = toUpperCase(user);
    uint8_t *u16, *d16; size_t u16len, d16len;
    toUTF16LE(upUser, &u16, &u16len);
    toUTF16LE(domain, &d16, &d16len);
    uint8_t *idbuf = (uint8_t*)malloc(u16len + d16len);
    memcpy(idbuf, u16, u16len);
    memcpy(idbuf + u16len, d16, d16len);
    free(u16); free(d16);

    // Ouvrir la wordlist
    File wf = SD.open("/evil/NTLM/ntlm_wordlist.txt", FILE_READ);
    if (!wf) {
      Serial.println("[ERROR] No /evil/NTLM/ntlm_wordlist.txt found");
      free(blob); free(msg); free(idbuf);
      continue;
    }
    const uint32_t totalBytes = wf.size();

    bool found = false;
    uint32_t tried = 0;
    uint32_t lastUpdateTried = 0;
    uint32_t lastUpdateTime  = millis();

    // OPT-1/3: Initialize buffered reading with dual-core prefetch
    CrackBufCtx cbuf;
    if (!crackBufInit(&cbuf, wf)) {
      Serial.println("[ERROR] PSRAM alloc failed for crack buffer");
      wf.close();
      free(blob); free(msg); free(idbuf);
      continue;
    }

    // OPT-14: Initialize dual-core hash worker
    CrackWorkerCtx worker;
    memset(&worker, 0, sizeof(worker));
    worker.idbuf = idbuf;
    worker.idlen = u16len + d16len;
    worker.msg = msg;
    worker.msgLen = msgLen;
    worker.ntProof = ntProof;
    worker.workReady = false;
    worker.workDone = false;
    worker.stopTask = false;
    worker.doneSem = xSemaphoreCreateBinary();
    xTaskCreatePinnedToCore(hashWorkerTask, "HashW", 8192, &worker, 2, &worker.taskHandle, 1);

    while (!found && !stopRequested) {
      // Fill batch from buffered SD
      int n = 0;
      while (n < CRACK_BATCH_SIZE) {
        int pwdLen = crackBufReadLine(&cbuf, worker.passwords[n], 65);
        if (pwdLen < 0) break; // EOF
        if (pwdLen == 0 || worker.passwords[n][0] == '#' || worker.passwords[n][0] == ';') continue;
        worker.pwdLens[n] = pwdLen;
        n++;
      }
      if (n == 0) break; // EOF

      // Split batch: Core 1 takes 2nd half, Core 0 takes 1st half
      int mid = n / 2;
      worker.startIdx = mid;
      worker.endIdx = n;
      worker.foundIdx = -1;
      worker.workDone = false;
      CRACK_MEM_BARRIER();
      xTaskNotifyGive(worker.taskHandle); // Wake hash worker on Core 1

      // Core 0 processes 1st half
      int foundLocal = -1;
      for (int i = 0; i < mid; i++) {
        uint8_t nthash[16];
        ntlmHashFast(worker.passwords[i], worker.pwdLens[i], nthash);
        uint8_t resp[16];
        crackNTLMv2_attempt(nthash, idbuf, u16len + d16len, msg, msgLen, resp);
        if (*(uint64_t*)resp == *(uint64_t*)ntProof &&
            *(uint64_t*)(resp+8) == *(uint64_t*)(ntProof+8)) {
          foundLocal = i;
          break;
        }
      }

      // Wait for Core 1 to finish its half
      while (!worker.workDone) { taskYIELD(); }
      CRACK_MEM_BARRIER();

      tried += n;

      // Check results from both cores
      if (foundLocal >= 0) {
        String foundMsg = "[SUCCESS] \nFOUND password for :\n" + user + ":" + String(worker.passwords[foundLocal]);
        Serial.println(foundMsg);
        drawNTLMResult(foundMsg, true);
        File foundFile = SD.open("/evil/NTLM/ntlm_found.txt", FILE_APPEND);
        if (foundFile) {
          foundFile.print(user); foundFile.print("::"); foundFile.print(domain);
          foundFile.print(": "); foundFile.println(worker.passwords[foundLocal]);
          foundFile.close();
        }
        delay(2000);
        found = true;
      } else if (worker.foundIdx >= 0) {
        String foundMsg = "[SUCCESS] \nFOUND password for :\n" + user + ":" + String(worker.passwords[worker.foundIdx]);
        Serial.println(foundMsg);
        drawNTLMResult(foundMsg, true);
        File foundFile = SD.open("/evil/NTLM/ntlm_found.txt", FILE_APPEND);
        if (foundFile) {
          foundFile.print(user); foundFile.print("::"); foundFile.print(domain);
          foundFile.print(": "); foundFile.println(worker.passwords[worker.foundIdx]);
          foundFile.close();
        }
        delay(2000);
        found = true;
      }

      // Display update — time-based (every 500ms) to minimize SPI overhead
      uint32_t now = millis();
      if (now - lastUpdateTime >= 500) {
        if (kp(KEY_BACKSPACE)) {
          Serial.println("[INFO] Skip requested -> next user");
          break;
        }
        if (isBackspacePressed()) {
          stopRequested = true;
          break;
        }
        drawNTLMTries(tried);
        drawProgressBar(cbuf.totalBytesRead, totalBytes);
        uint32_t elapsed = now - lastUpdateTime;
        if (elapsed > 0) {
          uint32_t hps = ((tried - lastUpdateTried) * 1000UL) / elapsed;
          drawHashrate(hps);
        }
        lastUpdateTried = tried;
        lastUpdateTime  = now;
      }
    }

    // Shutdown hash worker
    worker.stopTask = true;
    CRACK_MEM_BARRIER();
    xTaskNotifyGive(worker.taskHandle); // Wake worker so it sees stopTask
    xSemaphoreTake(worker.doneSem, pdMS_TO_TICKS(2000));
    vSemaphoreDelete(worker.doneSem);

    drawProgressBar(cbuf.totalBytesRead, totalBytes);
    crackBufFree(&cbuf);
    wf.close();

    if (!found) {
      Serial.print("[RESULT] No match in wordlist for user ");
      Serial.println(user);

      // --- FEEDBACK : résultat FAIL ---
      drawNTLMResult("[FAIL] \n No match for :\n " + user, false);
    }

    free(idbuf);
    free(msg);
    free(blob);

    delay(1000);
  }
  hf.close();
  waitAndReturnToMenu("Back To Main Menu");
}














struct CleanStats {
  uint32_t totalLines   = 0;
  uint32_t keptLines    = 0;
  uint32_t dupLines     = 0;
  uint32_t invalidLines = 0;
};

inline uint64_t fnv1a64_init() { return 1469598103934665603ULL; }
inline uint64_t fnv1a64_update(uint64_t h, const char* data, size_t len) {
  for (size_t i = 0; i < len; ++i) {
    h ^= (uint8_t)data[i];

// ===== Clean NTLMv2 Hashes =====
    h ^= (uint8_t)data[i];
    h *= 1099511628211ULL;
  }
  return h;
}

