// ===== RAINBOW WHEEL FOR TURBO MODE ================================
inline uint32_t wheel(byte pos) {
  if (pos < 85) return pixels.Color(pos * 3, 255 - pos * 3, 0);
  if (pos < 170) {
    pos -= 85;
    return pixels.Color(255 - pos * 3, 0, pos * 3);
  }
  pos -= 170; return pixels.Color(0, pos * 3, 255 - pos * 3);
}



