// Serve a portal HTML file with dynamic IP replacement
void servePortalFileWithReplace(const String &path, const String &replaceIP) {
  File f = SD.open(path);
  if (!f) { server.send(404, "text/plain", "File not found"); return; }
  server.setContentLength(CONTENT_LENGTH_UNKNOWN);
  server.send(200, "text/html", "");
  const size_t bufSize = 512;
  char buf[bufSize + 1];
  while (f.available()) {
    size_t len = f.readBytes(buf, bufSize);
    buf[len] = '\0';
    String chunk(buf);
    chunk.replace("192.168.4.1", replaceIP);
    server.sendContent(chunk);
  }
  f.close();
  server.sendContent("");
  server.client().stop();
}

