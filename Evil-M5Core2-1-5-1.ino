  taskBarCanvas.pushSprite(0, 0);
}

void loop() {
  kpSafeUpdate();
  navigatorInjectKeys();
  handleDnsRequestSerial();

  // ── One-shot boot launcher with cancellable countdown ──
  if (!bootLaunchDone) {
    bootLaunchDone = true;
    if (startAtBootFlag && caseToStartAtBoot >= 0 && caseToStartAtBoot < menuSize) {
      bool aborted = false;
      int secs = bootCountdownSeconds;
      if (secs < 0) secs = 0;
      if (secs > 30) secs = 30;
      if (secs > 0) {
        for (int t = secs; t > 0; --t) {
          M5.Display.clear();
          M5.Display.setTextSize(2);
          M5.Display.setTextColor(TFT_WHITE, TFT_BLACK);
          M5.Display.setCursor(10, 40);
          M5.Display.println("Auto-start in " + String(t) + " s");
          M5.Display.setCursor(10, 70);
          M5.Display.setTextColor(TFT_DARKGREY, TFT_BLACK);
          M5.Display.println("Press B to cancel");
          M5.Display.display();
          uint32_t t0 = millis();
          while (millis() - t0 < 1000) {
            kpSafeUpdate();
            if (kp(KEY_ENTER)) {
              aborted = true;
              break;
            }
            delay(10);
          }
          if (aborted) break;
        }
      }
      if (!aborted) {
        Serial.println(F("[BOOT] Auto-launch executing selected case"));
        executeMenuItem(caseToStartAtBoot);
        return; // skip normal loop this iteration
      }
      // If aborted, fall through to normal menu
      exitDebounce();
      inMenu = true;
      lastIndex = -1;
      drawMenu();
    }
  }

  unsigned long currentMillis = millis();

  // Mettre à jour la barre de tâches indépendamment du menu
  if (currentMillis - lastTaskBarUpdateTime >= taskBarUpdateInterval && inMenu) {
    drawTaskBar();
    lastTaskBarUpdateTime = currentMillis;
  }

  if (inMenu) {
    if (lastIndex != currentIndex) {
      drawMenu();
      lastIndex = currentIndex;
    }
    handleMenuInput();
  } else {
    switch (currentStateKarma) {
      case StartScanKarma:
        if (kp(KEY_ENTER)) {
          startScanKarma();
          currentStateKarma = ScanningKarma;
        }
        break;

      case ScanningKarma:
        if (kp(KEY_ENTER)) {
          isKarmaMode = true;
          stopScanKarma();
          currentStateKarma = ssid_count_Karma > 0 ? StopScanKarma : StartScanKarma;
        }
        break;

      case StopScanKarma:
        handleMenuInputKarma();
        break;

      case SelectSSIDKarma:
        handleMenuInputKarma();
        break;
    }

    if (kp(KEY_ENTER) && currentStateKarma == StartScanKarma) {
      exitDebounce();
      inMenu = true;
      isOperationInProgress = false;
    }
  }
}



