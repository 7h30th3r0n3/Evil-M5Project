void ddUpdateTileUploads(unsigned long v) {
  if (v == uiLastUp) return;
  uiLastUp = v;
  char buf[12]; snprintf(buf, sizeof(buf), "%lu", v);
  ddDrawValueInTile(DD_T_UP_X, DD_T_UP_Y, DD_T_W, DD_T_H, buf);
}
void ddUpdateTileDownloads(unsigned long v) {
  if (v == uiLastDown) return;
  uiLastDown = v;
  char buf[12]; snprintf(buf, sizeof(buf), "%lu", v);
  ddDrawValueInTile(DD_T_DW_X, DD_T_DW_Y, DD_T_W, DD_T_H, buf);
