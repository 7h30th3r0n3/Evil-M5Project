String ddUrlEncode(const String& in) {
  String o; o.reserve(in.length() * 3);
  for (size_t i = 0; i < in.length(); i++) {
    char c = in[i];
    bool safe = (c >= 'a' && c <= 'z') || (c >= 'A' && c <= 'Z') || (c >= '0' && c <= '9') || c == '-' || c == '_' || c == '.' || c == '~';
    if (safe) o += c;
    else { char buf[4]; snprintf(buf, sizeof(buf), "%%%02X", (unsigned char)c); o += buf; }
  }
  return o;
}

String ddHtmlEscape(const String& in) {
  String o; o.reserve(in.length() + 8);
  for (size_t i = 0; i < in.length(); i++) {
    char c = in[i];
    if (c == '<') o += "&lt;"; else if (c == '>') o += "&gt;";
    else if (c == '&') o += "&amp;"; else if (c == '"') o += "&quot;";
    else o += c;
  }
  return o;
}

String ddSafeName(const String& in) {
  String s = in;
  s.replace("\\", "_"); s.replace("/", "_"); s.replace("..", "_");
  s.replace("%", "_"); s.replace(":", "_"); s.replace("\"", "_"); s.replace("'", "_");
  s.trim();
  if (s.length() == 0) s = "drop.bin";
  return s;
}

String ddMimeFromExt(const String& name) {
  int dot = name.lastIndexOf('.');
  String ext = (dot >= 0) ? name.substring(dot + 1) : "";
  ext.toLowerCase();
  if (ext == "txt") return "text/plain";
  if (ext == "htm" || ext == "html") return "text/html";
  if (ext == "json") return "application/json";
  if (ext == "jpg" || ext == "jpeg") return "image/jpeg";
  if (ext == "png") return "image/png";
  if (ext == "pdf") return "application/pdf";
  if (ext == "csv") return "text/csv";
  if (ext == "zip") return "application/zip";
  return "application/octet-stream";
}

void handleDeadDropUpload() {
  HTTPUpload& upload = server.upload();
  if (!ddActive) return;
  if (upload.status == UPLOAD_FILE_START) {
    String safe = ddSafeName(upload.filename);
    String path = String(DD_BASE) + "/" + safe;
    if (!SD.exists(DD_BASE)) SD.mkdir(DD_BASE);
    ddUploadFile = SD.open(path, FILE_WRITE);
    if (ddUploadFile) Serial.printf("[DD] Upload start: %s\n", path.c_str());
  } else if (upload.status == UPLOAD_FILE_WRITE) {
    if (ddUploadFile) { ddUploadFile.write(upload.buf, upload.currentSize); ddBytesIn += upload.currentSize; }
  } else if (upload.status == UPLOAD_FILE_END) {
    if (ddUploadFile) { ddUploadFile.close(); ddUploadsCount++; }
    Serial.println(F("[DD] Upload done."));
  } else if (upload.status == UPLOAD_FILE_ABORTED) {
    if (ddUploadFile) ddUploadFile.close();
    Serial.println(F("[DD] Upload aborted."));
  }
}

