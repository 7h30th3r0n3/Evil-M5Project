#include <string.h>
#include <ctype.h>


// ===================== Config =====================
const uint32_t C5_BAUD = 115200;
const uint16_t C5_LINE_MAX = 240;
const uint32_t C5_GLOBAL_TIMEOUT_MS = 12000;
const uint32_t C5_IDLE_DONE_MS = 700;
volatile uint32_t g_c5_lastRxBlink = 0;

// Core2 pins: GPIO 32 (RX) / GPIO 33 (TX)
const int C5_RX_PIN = 32;
const int C5_TX_PIN = 33;

bool g_c5_uart_on = false;
bool g_c5_deauth_on = true;
char g_c5_band[6] = "ALL";
bool g_c5_ward_on = false;
bool g_c5_sniff_on = false;
uint8_t g_c5_ap_count = 0;

char g_c5_rxline[C5_LINE_MAX + 4];
uint16_t g_c5_rxpos = 0;
volatile uint32_t g_c5_lastAnyRx = 0;

// UART functions
void c5_uartBegin() {
  if (g_c5_uart_on) return;
  Serial2.end();  // Close GPS if open
  Serial2.setRxBufferSize(1024);
  Serial2.begin(C5_BAUD, SERIAL_8N1, C5_RX_PIN, C5_TX_PIN);
  g_c5_uart_on = true;
  g_c5_rxpos = 0;
  while (Serial2.available()) Serial2.read();  // flush
}

void c5_uartEnd() {
  if (!g_c5_uart_on) return;
  Serial2.end();
  g_c5_uart_on = false;
  Serial2.begin(baudrate_gps, SERIAL_8N1, gpsRxPin, gpsTxPin);  // Restore GPS
}

void c5_sendCmd(const char* cmd) {
  if (!g_c5_uart_on || !cmd) return;
  Serial2.print(cmd);
  Serial2.print("\n");
}

void c5_poll() {
  if (!g_c5_uart_on) return;
  while (Serial2.available()) {
    char c = (char)Serial2.read();
    if (c == '\r') continue;
    if (c == '\n') {
      g_c5_rxline[g_c5_rxpos] = 0;
      g_c5_rxpos = 0;
      g_c5_lastAnyRx = millis();
      g_c5_lastRxBlink = millis();
      continue;
    }
    if (g_c5_rxpos + 1 < C5_LINE_MAX) {
      g_c5_rxline[g_c5_rxpos++] = c;
    } else {
      g_c5_rxpos = 0;
    }
  }
}

