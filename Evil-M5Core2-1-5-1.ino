// ===== Hold-to-scroll repeat helper =====
struct HoldRepeat {
  bool held = false;
  bool initialDone = false;
  unsigned long lastTime = 0;

  bool update(bool pressed, unsigned long now,
              unsigned long initDelay = 400, unsigned long repDelay = 150) {
    if (pressed) {
      if (!held) { held = true; initialDone = false; lastTime = now; return true; }
      unsigned long d = initialDone ? repDelay : initDelay;
      if (now - lastTime >= d) { initialDone = true; lastTime = now; return true; }
    } else { held = false; initialDone = false; }
    return false;
  }
};

