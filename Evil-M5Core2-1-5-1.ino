    html += "<p><a href='/dd-list'>View Deposits</a></p>";
    html += "<script>function up(){var f=document.getElementById('f').files[0];if(!f){alert('Select a file');return;}";
    html += "var p=document.getElementById('prog'),s=document.getElementById('status');p.style.display='block';";
