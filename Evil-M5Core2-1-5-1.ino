// -- Helper function to read a line from the client --
String readLine(WiFiClient &client, bool echo) {
  String line = "";
  while (client.connected()) {
    if (client.available()) {
      char c = client.read();
      if (c == '\r') {
        continue; // Ignore CR
      }
      if (c == '\n') {
        break; // Fin de ligne
      }
      // Ajouter le caractère à la ligne sans jamais écho
      line += c;
    }
  }

  // Pas de gestion d'écho ici (pas de client.print)
  return line;
}


// ============================================================
// ===== CORE2 COMPATIBILITY LAYER FOR CARDPUTER FEATURES =====
// ============================================================

// kp() - Key press bridge for Core2 (replaces Cardputer keyboard)
// Maps keyboard keys to Core2 buttons:
//   KEY_ENTER / 'y' / ' ' -> BtnB (middle = select/yes/action)
//   KEY_BACKSPACE / 'n'   -> BtnA (left = back/no)
//   '.' / '/' / ','       -> BtnC (right = scroll down/next)
//   ';'                   -> BtnA (used for scroll up in some contexts)
// Other keys: return false (no keyboard on Core2)
// NOTE: Button states are cached per millisecond to avoid M5.update()
//       consuming wasPressed() on repeated calls in the same loop iteration.
// KEY_ENTER and KEY_BACKSPACE defined near top of file for early use

// ============================================================================
//  Navigator WebUI (Screen Streaming + Remote Control)
// ============================================================================

// ── Virtual key injection ────────────────────────────────────────────────────
enum NavAction : uint8_t {
  NAV_NONE = 0,
  NAV_UP,
  NAV_DOWN,
  NAV_ENTER,
  NAV_BACK,
  NAV_PGUP,
  NAV_PGDOWN,
};

static volatile NavAction navPendingAction = NAV_NONE;
static volatile unsigned long navActionTime = 0;

// Raw character injection from web keyboard (distinct from NavAction d-pad)
static volatile uint8_t  navPendingChar = 0;
static volatile bool     navPendingCharValid = false;

// Sticky button state cache: once a press is detected by ANY M5.update(),
// it stays latched until kp() reads and clears it.  This prevents explicit
// M5.update() calls elsewhere in the loop from "eating" the button event
// before kp() gets a chance to see it.
bool _kpA = false, _kpB = false, _kpC = false;

// kpSafeUpdate() - Drop-in replacement for M5.update() that accumulates
// button presses into the sticky cache.  Use this everywhere instead of
// raw M5.update() inside loops that also call kp().
inline void kpSafeUpdate() {
  M5.update();
  _kpA |= M5.BtnA.wasPressed();
  _kpB |= M5.BtnB.wasPressed();
  _kpC |= M5.BtnC.wasPressed();
}

inline bool kp(uint8_t key) {
  kpSafeUpdate();
  bool result = false;
  switch (key) {
    case KEY_ENTER: case 'y': case 'Y': case ' ':
      result = _kpB; if (result) _kpB = false; break;
    case KEY_BACKSPACE: case 'n': case 'N':
      result = _kpA; if (result) _kpA = false; break;
    case '.': case '/': case ',':
      result = _kpC; if (result) _kpC = false; break;
    case ';':
      result = _kpA; if (result) _kpA = false; break;
    default: break;
  }
  if (result) return true;
  // Check navigation d-pad actions from Navigator WebUI
  NavAction act = navPendingAction;
  if (act != NAV_NONE) {
    bool match = false;
    switch (act) {
      case NAV_UP:     match = (key == ';'); break;
      case NAV_DOWN:   match = (key == '.'); break;
      case NAV_ENTER:  match = (key == KEY_ENTER); break;
      case NAV_BACK:   match = (key == KEY_BACKSPACE); break;
      case NAV_PGUP:   match = (key == ','); break;
      case NAV_PGDOWN: match = (key == '/'); break;
      default: break;
    }
    if (match) { navPendingAction = NAV_NONE; return true; }
  }
  // Check raw character from web keyboard
  if (navPendingCharValid && navPendingChar == key) {
    navPendingCharValid = false;
    navPendingChar = 0;
    return true;
  }
  return false;
}

// kpAny() - Returns true if any button was pressed (clears all)
inline bool kpAny() {
  kpSafeUpdate();
  bool any = _kpA || _kpB || _kpC;
  if (any) { _kpA = false; _kpB = false; _kpC = false; }
  return any || (navPendingAction != NAV_NONE) || navPendingCharValid;
}

// ── Navigator: inject virtual keys into the main menu loop ───────────────────
void navigatorInjectKeys() {
  NavAction act = navPendingAction;
  if (act == NAV_NONE) return;

  // When not in menu, let kp() consume the action inside the function's own loop
  if (!inMenu) return;

  navPendingAction = NAV_NONE;

  switch (act) {
    case NAV_UP:
      if (inMenu) {
        currentIndex--;
        if (currentIndex < 0) currentIndex = menuSize - 1;
        menuStartIndex = max(0, min(currentIndex, menuSize - maxMenuDisplay));
        drawMenu();
        lastIndex = currentIndex;
      }
      break;

    case NAV_DOWN:
      if (inMenu) {
        currentIndex++;
        if (currentIndex >= menuSize) currentIndex = 0;
        menuStartIndex = max(0, min(currentIndex, menuSize - maxMenuDisplay));
        drawMenu();
        lastIndex = currentIndex;
      }
      break;

    case NAV_ENTER:
      if (inMenu) {
        executeMenuItem(currentIndex);
      }
      break;

    case NAV_BACK:
      // Core2 has no search/filter mode, so back is a no-op in menu
      break;

    case NAV_PGUP:
      if (inMenu) {
        currentIndex -= 3;
        while (currentIndex < 0) currentIndex += max(1, menuSize);
        menuStartIndex = max(0, min(currentIndex, menuSize - maxMenuDisplay));
        drawMenu();
        lastIndex = currentIndex;
      }
      break;

    case NAV_PGDOWN:
      if (inMenu) {
        currentIndex += 3;
        if (currentIndex >= menuSize) currentIndex %= max(1, menuSize);
        menuStartIndex = max(0, min(currentIndex, menuSize - maxMenuDisplay));
        drawMenu();
        lastIndex = currentIndex;
      }
      break;

    default:
      break;
  }
}

// ── Screen capture endpoint ──────────────────────────────────────────────────
// Reads and sends the TFT in horizontal strips to avoid a large heap buffer.
// Core2: 320×240 display, strip height 10 → 24 strips, buffer = 320×10×2 = 6400 bytes
static const int NAV_SCREEN_W = 320;
static const int NAV_SCREEN_H = 240;
static const int NAV_STRIP_H  = 10;   // 240 / 10 = 24 strips
static uint16_t navStripBuf[320 * 10];

void handleNavScreen() {
  if (!guardAdmin()) return;

  int dataSize = 4 + NAV_SCREEN_W * NAV_SCREEN_H * 2;
  server.setContentLength(dataSize);
  server.send(200, "application/octet-stream", "");

  uint8_t hdr[4];
  hdr[0] = (NAV_SCREEN_W >> 8) & 0xFF;
  hdr[1] = NAV_SCREEN_W & 0xFF;
  hdr[2] = (NAV_SCREEN_H >> 8) & 0xFF;
  hdr[3] = NAV_SCREEN_H & 0xFF;
  server.client().write(hdr, 4);

  for (int y = 0; y < NAV_SCREEN_H; y += NAV_STRIP_H) {
    int h = min(NAV_STRIP_H, NAV_SCREEN_H - y);
    M5.Display.readRect(0, y, NAV_SCREEN_W, h, navStripBuf);
    server.client().write((const uint8_t*)navStripBuf, NAV_SCREEN_W * h * 2);
    yield();
  }
}

// ── Input endpoint ───────────────────────────────────────────────────────────
void handleNavInput() {
  if (!guardAdmin()) return;

  String key = server.arg("key");

  // Navigation d-pad actions
  if      (key == "up")     navPendingAction = NAV_UP;
  else if (key == "down")   navPendingAction = NAV_DOWN;
  else if (key == "enter")  navPendingAction = NAV_ENTER;
  else if (key == "back")   navPendingAction = NAV_BACK;
  else if (key == "pgup")   navPendingAction = NAV_PGUP;
  else if (key == "pgdown") navPendingAction = NAV_PGDOWN;
  // Raw character from web keyboard (key=char&c=<decimal_code>)
  else if (key == "char") {
    int code = server.arg("c").toInt();
    if (code >= 0 && code < 256) {
      navPendingChar = (uint8_t)code;
      navPendingCharValid = true;
    } else {
      server.send(400, "text/plain", "Invalid code");
      return;
    }
  }
  else {
    server.send(400, "text/plain", "Unknown key");
    return;
  }

  navActionTime = millis();
  server.send(200, "text/plain", "OK");
}

