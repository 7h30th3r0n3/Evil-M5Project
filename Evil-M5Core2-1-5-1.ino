void scanWifiNetworks() {
  WiFi.mode(WIFI_STA);
  WiFi.disconnect();
  unsigned long startTime = millis();
  int n;
  while (millis() - startTime < 5000) {
    M5.Display.clear();
    M5.Display.fillRect(0, M5.Display.height() - 20, M5.Display.width(), 20, TFT_BLACK);
    M5.Display.setCursor(50 , M5.Display.height() / 2 );
    M5.Display.print("Scan in progress... ");
    Serial.println("-------------------");
    Serial.println("WiFi Scan in progress... ");
    M5.Display.display();
    n = WiFi.scanNetworks();
    if (n != WIFI_SCAN_RUNNING) break;
  }
  Serial.println("-------------------");
  Serial.println("Near Wifi Network : ");
  numSsid = min(n, 100);
  for (int i = 0; i < numSsid; i++) {
    ssidList[i] = WiFi.SSID(i);
    Serial.print(i);
    Serial.print(": ");
    Serial.println(ssidList[i]);
  }
  Serial.println("-------------------");
  Serial.println("WiFi Scan Completed ");
  Serial.println("-------------------");
  waitAndReturnToMenu("Scan Completed");

}


void showWifiList() {
  enterDebounce();
  if (numSsid == 0) { waitAndReturnToMenu("No networks found.\nScan first!"); return; }

  const int ROW_H = 24;
  const int SCROLL_W = 4;
  const int SCR_W = M5.Display.width();
  const int SCR_H = M5.Display.height();
  const int maxVisible = SCR_H / ROW_H;  // 10 lines on 240px
  bool redraw = true;
  HoldRepeat holdA, holdC;

  // Cache RSSI/security per network
  int rssiCache[100];
  bool lockedCache[100];
  int chCache[100];
  for (int i = 0; i < numSsid && i < 100; i++) {
    rssiCache[i] = WiFi.RSSI(i);
    lockedCache[i] = (WiFi.encryptionType(i) != WIFI_AUTH_OPEN);
    chCache[i] = WiFi.channel(i);
  }

  // Helper lambdas
  auto drawRssiBars = [&](int x, int y, int rssi) {
    int bars = (rssi > -50) ? 4 : (rssi > -65) ? 3 : (rssi > -75) ? 2 : 1;
    for (int b = 0; b < 4; b++) {
      int bh = 5 + b * 4;
      int bx = x + b * 6;
      int by = y + (20 - bh);
      if (b < bars) M5.Display.fillRect(bx, by, 4, bh, TFT_GREEN);
      else          M5.Display.fillRect(bx, by, 4, bh, TFT_DARKGREY);
    }
  };

  auto drawLockIcon = [&](int x, int y) {
    M5.Display.drawRect(x, y + 6, 10, 8, TFT_YELLOW);
    M5.Display.drawRect(x + 2, y + 1, 6, 6, TFT_YELLOW);
  };

  while (!inMenu) {
    if (redraw) {
      int top = max(0, min(currentListIndex, numSsid - maxVisible));
      M5.Display.fillScreen(TFT_BLACK);
      M5.Display.setTextSize(2);

      for (int i = top; i < min(numSsid, top + maxVisible); i++) {
        int rowY = (i - top) * ROW_H;
        if (i == currentListIndex) {
          M5.Display.fillRect(0, rowY, SCR_W - SCROLL_W, ROW_H, TFT_NAVY);
          M5.Display.setTextColor(TFT_GREEN, TFT_NAVY);
        } else {
          M5.Display.setTextColor(TFT_WHITE, TFT_BLACK);
        }

        // RSSI bars
        drawRssiBars(2, rowY + 2, rssiCache[i]);

        // Lock icon
        int nameX = 28;
        if (lockedCache[i]) {
          drawLockIcon(nameX, rowY + 2);
          nameX += 14;
        }

        // SSID name (truncate if too long)
        String name = ssidList[i];
        int maxNamePx = SCR_W - nameX - SCROLL_W - 6;
        while (M5.Display.textWidth(name) > maxNamePx && name.length() > 3) {
          name = name.substring(0, name.length() - 1);
        }
        if (name != ssidList[i]) name += "..";
        M5.Display.setCursor(nameX, rowY + 4);
        M5.Display.print(name);
      }

      // Scrollbar
      if (numSsid > maxVisible) {
        int thumbH = max(8, (SCR_H * maxVisible) / numSsid);
        int thumbY = (SCR_H - thumbH) * currentListIndex / max(1, numSsid - 1);
        M5.Display.fillRect(SCR_W - SCROLL_W, 0, SCROLL_W, SCR_H, TFT_BLACK);
        M5.Display.fillRect(SCR_W - SCROLL_W, thumbY, SCROLL_W, thumbH, TFT_DARKGREY);
      }

      M5.Display.display();
      redraw = false;
    }

    unsigned long now = millis();
    kpSafeUpdate();
    handleDnsRequestSerial();

    if (holdA.update(M5.BtnA.isPressed(), now)) {
      currentListIndex--;
      if (currentListIndex < 0) currentListIndex = numSsid - 1;
      redraw = true;
    } else if (holdC.update(M5.BtnC.isPressed(), now)) {
      currentListIndex++;
      if (currentListIndex >= numSsid) currentListIndex = 0;
      redraw = true;
    } else if (kp(KEY_ENTER)) {
      enterDebounce();
      inMenu = true;
      Serial.println("SSID " + ssidList[currentListIndex] + " selected");
      waitAndReturnToMenu(ssidList[currentListIndex] + "\nselected");
    }
    delay(20);
  }
}


void showWifiDetails(int &networkIndex) {
  inMenu = false;

  auto updateDisplay = [&]() {
    if (networkIndex >= 0 && networkIndex < numSsid) {
      M5.Display.clear();
