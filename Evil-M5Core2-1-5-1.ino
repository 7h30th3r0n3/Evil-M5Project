void generateRandomMAC(uint8_t *mac, uint16_t iteration) {
  // Select random OUI
  uint8_t index = random(0, sizeof(knownOUI) / sizeof(knownOUI[0]));
  mac[0] = knownOUI[index][0];
  mac[1] = knownOUI[index][1];
  mac[2] = knownOUI[index][2];

