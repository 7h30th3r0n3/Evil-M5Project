void selectTypesUI() {
  exitDebounce();
  for (int i = 0; i < kTypeCount; i++) gTypeEnabled[i] = true;
  selectAll = true;
  int cursor = 0;
  HoldRepeat holdA, holdC;

  // buffer état ancien
  int oldCursor = -1;
  bool oldSelectAll = !selectAll;
  bool oldEnabled[kTypeCount];
  for (int i=0;i<kTypeCount;i++) oldEnabled[i] = !gTypeEnabled[i];

  while (true) {
    // Redessine uniquement si changement
    bool needRedraw = (cursor != oldCursor) || (selectAll != oldSelectAll);
    for (int i=0;i<kTypeCount;i++) {
      if (gTypeEnabled[i] != oldEnabled[i]) { needRedraw = true; break; }
    }

    if (needRedraw) {
      auto& d = M5.Display;
      d.fillScreen(BLACK);
      d.setTextSize(2);
      d.setTextColor(TFT_WHITE, BLACK);

      // Ligne Select All
      d.setCursor(0, 0);
      if (cursor == 0) d.setTextColor(TFT_GREEN, BLACK); else d.setTextColor(TFT_WHITE, BLACK);
      d.printf("%s %s Select All\n", cursor == 0 ? ">" : " ", selectAll ? "[X]" : "[ ]");

      // Liste des types
      for (int i = 0; i < kTypeCount; i++) {
        d.setCursor(0, (i+1)*16);
        if (cursor == i+1) d.setTextColor(TFT_GREEN, BLACK); else d.setTextColor(TFT_WHITE, BLACK);
        d.printf("%s %s %s", cursor == i+1 ? ">" : " ", gTypeEnabled[i] ? "[X]" : "[ ]", shortType(kTypes[i]).c_str());
      }

      // Help bar
      d.setTextSize(1);
      d.setTextColor(TFT_DARKGREY, BLACK);
      d.setCursor(5, d.height()-12);
      d.print("A=Up B=OK C=Down PWR=Toggle");

      // maj état ancien
      oldCursor = cursor;
      oldSelectAll = selectAll;
      for (int i=0;i<kTypeCount;i++) oldEnabled[i] = gTypeEnabled[i];
    }

    // Gestion boutons Core2
    unsigned long now = millis();
    kpSafeUpdate();
    if (holdC.update(M5.BtnC.isPressed(), now)) { cursor++; if (cursor > kTypeCount) cursor = 0; }
    if (holdA.update(M5.BtnA.isPressed(), now)) { cursor--; if (cursor < 0) cursor = kTypeCount; }
    if (M5.BtnPWR.wasClicked()) {
      if (cursor == 0) {
        selectAll = !selectAll;
        for (int i = 0; i < kTypeCount; i++) gTypeEnabled[i] = selectAll;
      } else {
        gTypeEnabled[cursor-1] = !gTypeEnabled[cursor-1];
      }
    }
    if (kp(KEY_ENTER)) {
      break; // validé
    }
    delay(8);
  }
}




